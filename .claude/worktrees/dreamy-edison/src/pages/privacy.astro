---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy"
  description="Privacy policy for The Wine Guide."
  noindex
>
  <div class="max-w-[42rem] mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="font-heading text-[2rem] font-bold text-primary leading-tight">Privacy Policy</h1>
    <p class="mt-4 text-text-muted text-sm">Last updated: April 2026</p>

    <div class="prose mt-8">
      <p>
        This privacy policy explains how The Wine Guide collects and uses information when you visit our site.
      </p>
      <h2>Information we collect</h2>
      <p>
        We use analytics to understand how people use the site (pages visited, time on page, referral sources). This data is aggregated and does not identify individual visitors.
      </p>
      <h2>Affiliate links</h2>
      <p>
        This site contains affiliate links to third-party retailers. When you click these links, the retailer may set cookies on your device. We have no control over third-party cookie practices.
      </p>
      <h2>Cookies</h2>
      <p>
        We use minimal cookies necessary for the site to function. We do not sell data or use advertising cookies.
      </p>
      <h2>Contact</h2>
      <p>
        Questions? Reach us at hello@thewine.guide.
      </p>
    </div>
  </div>
</BaseLayout>

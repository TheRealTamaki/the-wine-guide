---
interface Score {
  critic: string;
  score: number;
}

interface Props {
  href: string;
  label: string;
  store: string;
  price?: string;
  image?: string;
  description?: string;
  scores?: Score[];
  pairings?: string[];
}

const { href, label, store, price, image, description, scores = [], pairings = [] } = Astro.props;

// Convert critic scores (typically 85-100) to a 5-star rating
function toStars(scores: Score[]): number {
  if (scores.length === 0) return 0;
  const avg = scores.reduce((sum, s) => sum + s.score, 0) / scores.length;
  // 90 = 4.0, 92 = 4.3, 94 = 4.6, 96 = 4.9, 100 = 5.0
  const stars = 4.0 + ((avg - 90) / 10);
  return Math.round(Math.min(5, Math.max(0, stars)) * 10) / 10;
}

const starRating = toStars(scores);
const fullStars = Math.floor(starRating);
const hasHalf = (starRating - fullStars) >= 0.3;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

function scoreColor(score: number): string {
  if (score >= 93) return 'var(--color-green-dark)';
  if (score >= 90) return 'var(--color-green)';
  return 'var(--color-secondary)';
}

const R = 18;
const CIRCUMFERENCE = 2 * Math.PI * R;

function scoreDash(score: number): string {
  const filled = (score / 100) * CIRCUMFERENCE;
  return `${filled.toFixed(2)} ${(CIRCUMFERENCE - filled).toFixed(2)}`;
}
---

<aside class="not-prose my-10 bg-surface-white border border-border rounded-[5px] overflow-hidden">
  <div class="flex flex-col sm:flex-row">
    {image && (
      <a href={href} rel="nofollow sponsored" target="_blank" class="flex-shrink-0 sm:w-44 w-full h-56 sm:h-auto bg-surface-low flex items-center justify-center p-4 no-underline">
        <img
          src={image}
          alt={label}
          class="max-h-48 sm:max-h-full w-auto object-contain drop-shadow-md"
          loading="lazy"
          decoding="async"
        />
      </a>
    )}
    <div class="flex-1 min-w-0 p-5 sm:p-6">
      <p class="text-xs font-bold uppercase tracking-widest text-accent mb-1">{store}</p>
      <h3 class="font-heading font-bold text-primary text-xl leading-snug mb-1">{label}</h3>
      {scores.length > 0 && (
        <div class="flex items-center gap-1 mb-2">
          {Array.from({ length: fullStars }).map(() => (
            <svg class="w-4 h-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
          {hasHalf && (
            <svg class="w-4 h-4" viewBox="0 0 20 20">
              <defs><linearGradient id={`half-${label.replace(/\s/g, '')}`}><stop offset="50%" stop-color="#fbbf24" /><stop offset="50%" stop-color="#d1d5db" /></linearGradient></defs>
              <path fill={`url(#half-${label.replace(/\s/g, '')})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          )}
          {Array.from({ length: emptyStars }).map(() => (
            <svg class="w-4 h-4 text-gray-300" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          ))}
          <span class="text-xs text-text-muted ml-1">{starRating.toFixed(1)}</span>
        </div>
      )}

      {description && (
        <p class="text-sm text-text-muted leading-relaxed mb-4">{description}</p>
      )}

      {scores.length > 0 && (
        <div class="flex items-center gap-5 mb-4 flex-nowrap overflow-x-auto">
          {scores.map((s) => (
            <div class="flex items-center gap-2 flex-shrink-0">
              <div class="relative w-11 h-11">
                <svg viewBox="0 0 40 40" class="w-11 h-11 -rotate-90" style="shape-rendering: geometricPrecision;">
                  <circle cx="20" cy="20" r={R} fill="none" stroke="var(--color-border)" stroke-width="2.5" opacity="0.4" />
                  <circle
                    cx="20" cy="20" r={R} fill="none"
                    stroke={scoreColor(s.score)}
                    stroke-width="2.5"
                    stroke-dasharray={scoreDash(s.score)}
                    stroke-linecap="round"
                  />
                </svg>
                <span class="absolute inset-0 flex items-center justify-center text-xs font-bold text-primary">{s.score}</span>
              </div>
              <span class="text-xs text-text-muted leading-tight whitespace-nowrap">{s.critic}</span>
            </div>
          ))}
        </div>
      )}

      {pairings.length > 0 && (
        <div class="mb-4">
          <span class="text-xs font-bold uppercase tracking-wider text-primary">Great with: </span>
          <span class="text-sm text-text-muted">{pairings.join(' · ')}</span>
        </div>
      )}

      <div class="flex items-center gap-4 flex-wrap justify-center sm:justify-start">
        {price && (
          <span class="text-base font-bold text-primary">{price}</span>
        )}
        <a
          href={href}
          rel="nofollow sponsored"
          target="_blank"
          class="affiliate-cta-btn inline-flex items-center gap-2 text-white text-sm font-bold px-6 py-3 no-underline transition-all duration-200 cursor-pointer uppercase tracking-widest rounded-[5px]"
        >
          Check Price on {store}
        </a>
      </div>
    </div>
  </div>
</aside>

<style>
  .affiliate-cta-btn {
    background-color: #6ab165;
    color: #ffffff !important;
  }
  .affiliate-cta-btn:hover {
    background-color: #5a9a56;
    color: #ffffff !important;
  }
</style>

---
interface Pick {
  rank: number;
  label: string;
  slug: string;
  highlight: string;
  image: string;
  href: string;
  rating?: number;
}

interface Props {
  picks: Pick[];
}

const { picks } = Astro.props;
---

{picks.length > 0 && (
  <div class="mt-6 pt-6 border-t border-border">
    <h4 class="text-sm font-bold text-primary uppercase tracking-widest mb-4">Our Top 3 Picks</h4>
    <div class="space-y-3">
      {picks.map((pick) => (
        <div class="top-pick-card relative rounded-[5px] border-2 border-border bg-surface-white overflow-hidden transition-all duration-200">
          <div class="absolute top-0 left-0 w-6 h-6 flex items-center justify-center text-[10px] font-bold text-white z-10 rounded-br-[5px]" style="background-color: #6ab165;">
            #{pick.rank}
          </div>
          <a href={pick.href} rel="nofollow sponsored" target="_blank" class="block no-underline">
            <div class="flex items-center gap-3 p-2.5">
              {pick.image && (
                <div class="flex-shrink-0 w-12 h-16 flex items-center justify-center">
                  <img
                    src={pick.image}
                    alt={pick.label}
                    class="max-h-14 w-auto object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold text-primary leading-tight line-clamp-2">{pick.label}</p>
                <p class="text-[10px] text-text-muted mt-0.5">{pick.highlight}</p>
                {pick.rating && (
                  <div class="flex items-center gap-0.5 mt-1">
                    {Array.from({ length: Math.floor(pick.rating) }).map(() => (
                      <svg class="w-3 h-3 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    ))}
                    {(pick.rating - Math.floor(pick.rating)) >= 0.3 && (
                      <svg class="w-3 h-3" viewBox="0 0 20 20">
                        <defs><linearGradient id={`tp-half-${pick.rank}`}><stop offset="50%" stop-color="#fbbf24" /><stop offset="50%" stop-color="#d1d5db" /></linearGradient></defs>
                        <path fill={`url(#tp-half-${pick.rank})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    )}
                    {Array.from({ length: 5 - Math.floor(pick.rating) - ((pick.rating - Math.floor(pick.rating)) >= 0.3 ? 1 : 0) }).map(() => (
                      <svg class="w-3 h-3 text-gray-300" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    ))}
                    <span class="text-[10px] text-text-muted ml-0.5">{pick.rating.toFixed(1)}</span>
                  </div>
                )}
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
)}

<style>
  .top-pick-card:hover {
    border-color: #6ab165;
  }
</style>

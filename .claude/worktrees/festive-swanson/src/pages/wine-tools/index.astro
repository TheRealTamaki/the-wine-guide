---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ui/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', (a) =>
  a.data.category === 'wine-tools' && !a.data.draft
)).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Wine Tools"
  description="The gear worth having: openers, decanters, glasses, chillers, and storage solutions."
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <header class="max-w-[42rem] mb-10">
      <span class="text-xs font-semibold uppercase tracking-wider text-accent">Wine Tools</span>
      <h1 class="mt-2 font-heading text-[2rem] font-bold text-primary leading-tight">Wine Tools</h1>
      <p class="mt-3 text-lg text-secondary leading-relaxed">The gear worth having: openers, decanters, glasses, chillers, and storage solutions.</p>
    </header>

    {articles.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => {
          const slug = article.id.replace('wine-tools/', '').replace(/\.mdx?$/, '');
          return (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/wine-tools/${slug}/`}
              category={article.data.category}
              date={article.data.publishDate}
              ogImage={article.data.ogImage}
            />
          );
        })}
      </div>
    ) : (
      <p class="text-text-muted">Guides coming soon.</p>
    )}
  </div>
</BaseLayout>

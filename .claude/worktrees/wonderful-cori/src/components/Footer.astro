---
import { footerLinks } from '../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="w-full rounded-t-[var(--twg-radius-lg)] mt-20 bg-bg">
  <div class="flex flex-col md:flex-row justify-between items-center p-12 gap-8 w-full max-w-7xl mx-auto">
    <!-- Wordmark -->
    <a
      href="/"
      class="font-heading font-bold text-primary text-2xl hover:text-accent transition-colors duration-300 cursor-pointer"
    >
      The Wine Guide
    </a>

    <!-- Links -->
    <div class="flex flex-wrap justify-center gap-8 text-sm uppercase tracking-widest">
      {footerLinks.map((link) => (
        <a
          href={link.href}
          class="text-text hover:text-green transition-all duration-200 cursor-pointer"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Copyright -->
    <div class="text-sm uppercase tracking-widest text-text-muted text-center md:text-right">
      &copy; {currentYear} The Wine Guide
    </div>
  </div>
</footer>

---
import { navGroups } from '../data/navigation';
---

<!-- Nav row -->
<nav class="twg-nav" aria-label="Main navigation">
  <div class="twg-wrap twg-nav-inner">
    <div class="twg-nav-left">
      {navGroups.map((group) => (
        <div class="twg-dropdown">
          <button class="twg-dropdown-trigger" aria-haspopup="true" aria-expanded="false">
            {group.label} <span class="twg-caret" aria-hidden="true">&#9662;</span>
          </button>
          <div class="twg-dropdown-panel" role="menu">
            {group.items.map((item) => (
              <a href={item.href} class="twg-dropdown-item" role="menuitem">
                <span class="twg-dropdown-label">{item.label}</span>
                {item.description && (
                  <span class="twg-dropdown-desc">{item.description}</span>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
    <a href="/" class="twg-logo" aria-label="The Wine Guide: Home">
      <svg class="twg-logo-mark" viewBox="0 0 128 128" aria-hidden="true" focusable="false">
        <rect x="24" y="28" width="80" height="92" rx="9" fill="currentColor"></rect>
        <path d="M24 82h80v38L64 92l-40 28V82Z" fill="currentColor"></path>
        <path d="M60 31c-4-11-11-20-20-26" fill="none" stroke="#8a8177" stroke-width="8" stroke-linecap="round"></path>
        <path d="M65 30c5-12 13-19 26-22" fill="none" stroke="#8a8177" stroke-width="8" stroke-linecap="round"></path>
        <path d="M63 13v24" fill="none" stroke="var(--twg-bg)" stroke-width="6" stroke-linecap="round"></path>
        <g fill="var(--twg-bg)">
          <circle cx="46" cy="57" r="8"></circle>
          <circle cx="64" cy="57" r="8"></circle>
          <circle cx="82" cy="57" r="8"></circle>
          <circle cx="55" cy="73" r="8"></circle>
          <circle cx="73" cy="73" r="8"></circle>
          <circle cx="46" cy="89" r="8"></circle>
          <circle cx="64" cy="89" r="8"></circle>
          <circle cx="82" cy="89" r="8"></circle>
          <circle cx="64" cy="105" r="8"></circle>
        </g>
      </svg>
      <span class="twg-logo-copy">
        The Wine Guide
        <small>Wine Guides For Beginners</small>
      </span>
    </a>
    <div class="twg-nav-right">
      <button id="search-trigger" aria-label="Open search" title="Search (⌘K)">Search &#8981;</button>
      <!-- Mobile hamburger (right side hidden on desktop) -->
      <button
        id="twg-mobile-toggle"
        class="twg-hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="twg-mobile-menu"
      >&#9776;</button>
    </div>
  </div>
</nav>

<!-- Mobile drawer -->
<div id="twg-mobile-menu" class="twg-mobile-menu" aria-hidden="true">
  <div id="twg-mobile-backdrop" class="twg-mobile-backdrop"></div>
  <nav class="twg-mobile-drawer" aria-label="Mobile navigation">
    <button id="twg-mobile-close" class="twg-mobile-close" aria-label="Close navigation">&#10005;</button>
    <ul class="twg-mobile-links">
      {navGroups.flatMap((group) =>
        group.items.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))
      )}
      <li><button class="twg-mobile-search" onclick="document.dispatchEvent(new Event('open-search'))">Search</button></li>
    </ul>
  </nav>
</div>

<script>
  const toggle = document.getElementById('twg-mobile-toggle');
  const closeBtn = document.getElementById('twg-mobile-close');
  const menu = document.getElementById('twg-mobile-menu');
  const backdrop = document.getElementById('twg-mobile-backdrop');

  function openMenu() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });

  document.getElementById('search-trigger')?.addEventListener('click', () => {
    document.dispatchEvent(new Event('open-search'));
  });
</script>

<style>
  /* Tokens mirroring the homepage design tokens */
  :root {
    --twg-ink: #1f1f1f;
    --twg-bg: #f4efe6;
    --twg-ink-soft: #3a3530;
    --twg-terracotta: #8a4a2f;
    --twg-burgundy: #5a1a2b;
    --twg-serif: 'Playfair Display', Georgia, serif;
    --twg-sans: 'Inter', system-ui, sans-serif;
    --twg-mono: 'JetBrains Mono', ui-monospace, monospace;
    --twg-rule: 1.5px;
    --twg-pad: 28px;
    --twg-max: 1440px;
  }

  /* Nav row */
  .twg-nav {
    border-bottom: var(--twg-rule) solid var(--twg-ink);
    background: var(--twg-bg);
    position: relative;
    z-index: 100;
  }

  .twg-nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 80px;
    padding: 0;
    gap: 24px;
  }

  .twg-nav-left,
  .twg-nav-right {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .twg-nav-right {
    justify-content: flex-end;
    gap: 28px;
  }

  .twg-nav-right a,
  #search-trigger {
    font-family: var(--twg-sans);
    font-size: 13px;
    letter-spacing: 0.04em;
    font-weight: 500;
    color: var(--twg-ink);
    text-decoration: none;
    padding-bottom: 2px;
    transition: opacity 0.15s ease;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .twg-nav-right a:hover,
  #search-trigger:hover {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .twg-mobile-search {
    display: block;
    width: 100%;
    text-align: left;
    padding: 14px 0;
    font-family: var(--twg-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--twg-ink);
    background: transparent;
    border: none;
    cursor: pointer;
    letter-spacing: 0.02em;
  }

  .twg-mobile-search:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Dropdown trigger button */
  .twg-dropdown {
    position: relative;
  }

  .twg-dropdown-trigger {
    background: transparent;
    border: none;
    font-family: var(--twg-sans);
    font-size: 13px;
    letter-spacing: 0.04em;
    font-weight: 500;
    color: var(--twg-ink);
    cursor: pointer;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    line-height: 1;
    transition: opacity 0.15s ease;
  }

  .twg-dropdown-trigger:hover {
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  .twg-caret {
    font-size: 9px;
    opacity: 0.7;
    transition: transform 0.15s ease;
  }

  /* Dropdown panel */
  .twg-dropdown-panel {
    position: absolute;
    top: 100%;
    left: 0;
    padding-top: 12px;
    background: var(--twg-ink);
    border: var(--twg-rule) solid var(--twg-ink);
    min-width: 260px;
    display: none;
    flex-direction: column;
    z-index: 200;
  }

  /* Show on hover of the group wrapper */
  .twg-dropdown:hover .twg-dropdown-panel {
    display: flex;
  }

  .twg-dropdown:hover .twg-caret {
    transform: rotate(180deg);
  }

  /* Dropdown items */
  .twg-dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 14px 18px;
    text-decoration: none;
    border-bottom: 1px solid rgba(244, 239, 230, 0.12);
    transition: background 0.12s ease;
  }

  .twg-dropdown-item:last-child {
    border-bottom: none;
  }

  .twg-dropdown-item:hover {
    background: rgba(244, 239, 230, 0.08);
  }

  .twg-dropdown-label {
    font-family: var(--twg-sans);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--twg-bg);
  }

  .twg-dropdown-desc {
    font-family: var(--twg-sans);
    font-size: 11.5px;
    color: rgba(244, 239, 230, 0.62);
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  /* Logo */
  .twg-logo {
    font-family: var(--twg-serif);
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
    line-height: 1;
    font-style: italic;
    color: var(--twg-burgundy);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .twg-logo-mark {
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    color: var(--twg-burgundy);
  }

  .twg-logo-copy {
    display: block;
    color: var(--twg-ink);
  }

  .twg-logo small {
    display: block;
    font-family: var(--twg-mono);
    font-size: 9px;
    letter-spacing: 0.3em;
    font-style: normal;
    margin-top: 4px;
    color: var(--twg-ink-soft);
    text-transform: uppercase;
  }

  /* Shared wrap */
  .twg-wrap {
    max-width: var(--twg-max);
    margin: 0 auto;
    padding: 0 var(--twg-pad);
  }

  /* Hamburger — hidden on desktop */
  .twg-hamburger {
    display: none;
    background: transparent;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: var(--twg-ink);
    padding: 4px;
    line-height: 1;
  }

  /* Mobile menu */
  .twg-mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9000;
  }

  .twg-mobile-menu.is-open {
    display: block;
  }

  .twg-mobile-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .twg-mobile-drawer {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 280px;
    background: var(--twg-bg);
    padding: 32px 28px;
    overflow-y: auto;
    border-right: var(--twg-rule) solid var(--twg-ink);
  }

  .twg-mobile-close {
    background: transparent;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--twg-ink);
    padding: 0;
    margin-bottom: 32px;
    display: block;
  }

  .twg-mobile-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .twg-mobile-links li {
    border-top: var(--twg-rule) solid var(--twg-ink);
  }

  .twg-mobile-links li:last-child {
    border-bottom: var(--twg-rule) solid var(--twg-ink);
  }

  .twg-mobile-links a {
    display: block;
    padding: 14px 0;
    font-family: var(--twg-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--twg-ink);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .twg-mobile-links a:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .twg-nav-inner {
      grid-template-columns: 1fr auto 1fr;
      padding: 24px 0;
    }

    .twg-nav-left {
      display: none;
    }

    /* Right side: only show hamburger */
    .twg-nav-right a {
      display: none;
    }

    .twg-hamburger {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .twg-logo {
      font-size: 22px;
      gap: 8px;
    }

    .twg-logo-mark {
      width: 29px;
      height: 29px;
    }

    .twg-logo small {
      font-size: 7px;
      letter-spacing: 0.22em;
    }
  }
</style>

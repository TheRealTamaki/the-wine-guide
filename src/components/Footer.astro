---
import { footerLinks } from '../data/navigation';

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg-alt mt-16">
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <a
          href="/"
          class="font-heading font-bold text-lg text-primary hover:text-accent transition-colors duration-200 cursor-pointer"
        >
          The Wine Guide
        </a>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">
          Honest recommendations and real knowledge for everyday wine drinkers.
          No jargon, no nonsense — just good wine advice.
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-2">
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-text-muted hover:text-accent transition-colors duration-200 cursor-pointer"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-border flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-xs text-text-muted">
        &copy; {currentYear} The Wine Guide. All rights reserved.
      </p>
      <p class="text-xs text-text-muted max-w-[28rem]">
        <strong>Affiliate disclosure:</strong> We may earn a commission when you buy through links on this site, at no extra cost to you. We only recommend products we genuinely believe in.
      </p>
    </div>
  </div>
</footer>

---
/**
 * StyleSelectorStrip — sticky pill-filter row for style-bucketed listicle pages.
 *
 * Usage (MDX):
 *   import StyleSelectorStrip from '../../../components/content/StyleSelectorStrip.astro';
 *   <StyleSelectorStrip categories={[
 *     { key: 'all',           label: 'All',              count: 20 },
 *     { key: 'red',           label: 'Red',              count: 7  },
 *     { key: 'white',         label: 'White',            count: 6  },
 *     { key: 'rose-sparkling',label: 'Rose and Sparkling', count: 7  },
 *   ]} />
 *
 * Each wine section in the MDX must be wrapped in a div with data-wine-style:
 *   <div data-wine-style="red"> ... </div>
 *   <div data-wine-style="white"> ... </div>
 *   <div data-wine-style="rose-sparkling"> ... </div>
 *
 * The `key` values match data-wine-style attribute values exactly.
 * The 'all' key is a special sentinel that shows everything.
 *
 * No-JS fallback: all wine sections remain visible (graceful degradation).
 * Scroll-into-view on mount: intentionally omitted (Dae hard rule).
 */

interface Props {
  categories: Array<{
    key: string;
    label: string;
    count: number;
  }>;
}

const { categories } = Astro.props;
---

<div class="not-prose style-selector-strip" data-style-strip>
  <div
    role="group"
    aria-label="Filter wines by style"
    class="strip-inner"
  >
    {categories.map((cat, i) => (
      <button
        type="button"
        class="strip-pill"
        data-style-key={cat.key}
        aria-pressed={i === 0 ? 'true' : 'false'}
      >
        {cat.label}
        <span class="strip-pill-count" aria-hidden="true">({cat.count})</span>
        <span class="sr-only">, {cat.count} {cat.count === 1 ? 'wine' : 'wines'}</span>
      </button>
    ))}
  </div>
</div>

<script is:inline>
  (function () {
    var strip = document.querySelector('[data-style-strip]');
    if (!strip) return;

    var pills = Array.from(strip.querySelectorAll('[data-style-key]'));
    if (!pills.length) return;

    /* Find all filterable wine sections in the article body.
       Look upward from the strip to find the nearest article or main container,
       then query within it. Fall back to document-level search. */
    function getWineGroups() {
      return Array.from(document.querySelectorAll('[data-wine-style]'));
    }

    function activate(key) {
      /* Update pill aria-pressed states */
      pills.forEach(function (pill) {
        var isActive = pill.getAttribute('data-style-key') === key;
        pill.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        pill.classList.toggle('is-active', isActive);
      });

      /* Show/hide wine sections */
      var groups = getWineGroups();
      groups.forEach(function (group) {
        var style = group.getAttribute('data-wine-style');
        var visible = key === 'all' || style === key;
        if (visible) {
          group.classList.remove('style-hidden');
          group.setAttribute('aria-hidden', 'false');
        } else {
          group.classList.add('style-hidden');
          group.setAttribute('aria-hidden', 'true');
        }
      });
    }

    /* Initial state: 'all' selected (first pill assumed to be 'all') */
    var initialKey = pills[0] ? pills[0].getAttribute('data-style-key') : 'all';
    activate(initialKey);

    strip.addEventListener('click', function (e) {
      var pill = e.target.closest('[data-style-key]');
      if (!pill) return;
      var key = pill.getAttribute('data-style-key');
      activate(key);
    });

    /* Keyboard: Enter/Space already handled natively by button type.
       Arrow key navigation across pills for enhanced UX. */
    strip.addEventListener('keydown', function (e) {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      var idx = pills.indexOf(document.activeElement);
      if (idx === -1) return;
      var next = e.key === 'ArrowRight'
        ? pills[(idx + 1) % pills.length]
        : pills[(idx - 1 + pills.length) % pills.length];
      next.focus();
      e.preventDefault();
    });
  })();
</script>

<style>
  /* ── Strip wrapper — sticky positioning ─────────────────────────────────── */
  .style-selector-strip {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 2px 8px rgba(30, 27, 19, 0.06);
    padding: 0.625rem 0;
    /* Extend to full content width — escapes prose max-width constraint */
    margin-left: -1.5rem;
    margin-right: -1.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  /* ── Inner row ───────────────────────────────────────────────────────────── */
  .strip-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  /* ── Pill — ghost / inactive state ──────────────────────────────────────── */
  .strip-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    padding: 0.375rem 0.875rem;
    border-radius: 999px;
    border: 1.5px solid var(--color-border-dark);
    background-color: transparent;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    cursor: pointer;
    transition:
      background-color 0.18s ease,
      border-color 0.18s ease,
      color 0.18s ease,
      box-shadow 0.18s ease;
    white-space: nowrap;
  }

  .strip-pill:hover:not(.is-active) {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background-color: var(--color-bg-alt);
  }

  .strip-pill:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* ── Pill — active / selected state ─────────────────────────────────────── */
  .strip-pill.is-active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #ffffff;
    box-shadow: 0 2px 6px rgba(87, 0, 19, 0.25);
  }

  .strip-pill.is-active:focus-visible {
    outline: 2px solid var(--color-accent-light);
    outline-offset: 2px;
  }

  /* ── Count badge ─────────────────────────────────────────────────────────── */
  .strip-pill-count {
    font-size: 0.8em;
    opacity: 0.75;
  }

  .strip-pill.is-active .strip-pill-count {
    opacity: 0.85;
  }

  /* ── Hidden wine sections — fade transition, not abrupt display:none ─────── */
  :global([data-wine-style]) {
    transition: opacity 0.22s ease;
  }

  :global([data-wine-style].style-hidden) {
    display: none;
  }

  /* ── Screen-reader only ─────────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Reduced motion ─────────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .strip-pill,
    :global([data-wine-style]) {
      transition: none !important;
    }
  }

  /* ── Mobile: make pills slightly smaller ────────────────────────────────── */
  @media (max-width: 480px) {
    .strip-pill {
      font-size: 0.8125rem;
      padding: 0.3rem 0.7rem;
    }
  }
</style>

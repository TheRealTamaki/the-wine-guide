---
interface Props {
  href: string;
  chapter: string;
  title: string;
  teaser: string;
}
const { href, chapter, title, teaser } = Astro.props;
---

<a href={href} class="next-chapter">
  <div class="nc-label">{chapter}</div>
  <div class="nc-body">
    <div class="nc-title">{title}</div>
    <p class="nc-teaser">{teaser}</p>
  </div>
  <div class="nc-arrow">Continue&nbsp;&rarr;</div>
</a>

<style>
.next-chapter {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 28px;
  margin-top: 56px;
  padding: 32px 36px;
  background: #1f1f1f;
  color: #f4efe6;
  text-decoration: none;
  border: 1.5px solid #1f1f1f;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.next-chapter:hover {
  transform: translate(-3px, -3px);
  box-shadow: 6px 6px 0 #5a1a2b;
  text-decoration: none;
  color: #f4efe6;
}

.nc-label {
  font-family: 'JetBrains Mono', ui-monospace, monospace;
  font-size: 10px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: #8a4a2f;
  white-space: nowrap;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  border-right: 1.5px solid rgba(244,239,230,0.2);
  padding-right: 20px;
}

.nc-body {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.nc-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 500;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.nc-teaser {
  font-size: 14px;
  line-height: 1.6;
  color: rgba(244,239,230,0.75);
  margin: 0;
  max-width: 60ch;
}

.nc-arrow {
  font-family: 'JetBrains Mono', ui-monospace, monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  white-space: nowrap;
  padding: 12px 20px;
  border: 1.5px solid rgba(244,239,230,0.3);
}

.next-chapter:hover .nc-arrow {
  background: #5a1a2b;
  border-color: #5a1a2b;
}

@media (max-width: 680px) {
  .next-chapter {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 28px 24px;
  }

  .nc-label {
    writing-mode: horizontal-tb;
    transform: none;
    border-right: 0;
    border-bottom: 1.5px solid rgba(244,239,230,0.2);
    padding-right: 0;
    padding-bottom: 16px;
  }

  .nc-arrow {
    align-self: flex-start;
  }
}
</style>

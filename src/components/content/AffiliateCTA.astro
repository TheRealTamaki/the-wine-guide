---
interface Props {
  href: string;
  label: string;
  store: string;
  price?: string;
  image?: string;
  description?: string;
}

const { href, label, store, price, image, description } = Astro.props;
---

<aside class="not-prose my-8 bg-surface-low border border-border overflow-hidden">
  <div class="flex items-start gap-6 p-6">
    {image && (
      <div class="flex-shrink-0 w-24 h-24 overflow-hidden bg-surface-white border border-border">
        <img src={image} alt={label} class="w-full h-full object-contain p-2" loading="lazy" decoding="async" />
      </div>
    )}
    <div class="flex-1 min-w-0">
      <p class="text-xs font-bold uppercase tracking-widest text-accent mb-1">{store}</p>
      <h3 class="font-heading font-bold text-primary text-lg leading-snug">{label}</h3>
      {description && (
        <p class="mt-2 text-sm text-text-muted leading-relaxed">{description}</p>
      )}
      <div class="mt-4 flex items-center gap-4 flex-wrap">
        {price && (
          <span class="text-base font-bold text-primary">{price}</span>
        )}
        <a
          href={href}
          rel="nofollow sponsored"
          target="_blank"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white text-sm font-bold px-6 py-3 no-underline transition-all duration-200 cursor-pointer uppercase tracking-widest"
        >
          View on {store}
          <span class="material-symbols-outlined text-sm">open_in_new</span>
        </a>
      </div>
    </div>
  </div>
</aside>

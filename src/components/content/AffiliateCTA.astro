---
interface Props {
  href: string;
  label: string;
  store: string;
  price?: string;
  image?: string;
  description?: string;
}

const { href, label, store, price, image, description } = Astro.props;
---

<aside class="not-prose my-6 bg-cta-light border border-cta/20 rounded-xl overflow-hidden">
  <div class="flex items-start gap-4 p-5">
    {image && (
      <div class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden bg-white border border-border">
        <img src={image} alt={label} class="w-full h-full object-contain p-1" loading="lazy" decoding="async" />
      </div>
    )}
    <div class="flex-1 min-w-0">
      <p class="text-xs font-semibold uppercase tracking-wider text-cta mb-1">{store}</p>
      <h3 class="font-heading font-semibold text-primary text-base leading-snug">{label}</h3>
      {description && (
        <p class="mt-1 text-sm text-secondary leading-relaxed">{description}</p>
      )}
      <div class="mt-3 flex items-center gap-3 flex-wrap">
        {price && (
          <span class="text-sm font-semibold text-primary">{price}</span>
        )}
        <a
          href={href}
          rel="nofollow sponsored"
          target="_blank"
          class="inline-flex items-center gap-1.5 bg-cta hover:bg-cta-hover text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200 cursor-pointer"
        >
          View on {store}
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</aside>

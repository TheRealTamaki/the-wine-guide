---
interface Pick {
  rank: number;
  label: string;
  href: string;
  image: string;
  score: number;
  critic: string;
  region: string;
  grape: string;
  pairings: string[];
}

interface Props {
  picks: Pick[];
}

const { picks } = Astro.props;

function toStars(score: number): number {
  const stars = 4.0 + ((score - 90) / 10);
  return Math.round(Math.min(5, Math.max(0, stars)) * 10) / 10;
}

const rankLabels = ['Best Overall', 'Runner-Up', 'Best Value'];
---

<div class="not-prose my-10">
  <div class="top-picks-header flex items-center gap-4 mb-5">
    <div class="h-px flex-1 bg-border"></div>
    <div class="flex items-center gap-2 px-1">
      <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
      <h3 class="font-heading font-bold text-primary text-xl sm:text-2xl m-0 tracking-tight">Our Top 3 Picks</h3>
    </div>
    <div class="h-px flex-1 bg-border"></div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    {picks.map((pick, i) => {
      const stars = toStars(pick.score);
      const fullStars = Math.floor(stars);
      const hasHalf = (stars - fullStars) >= 0.3;
      const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

      return (
        <div class={`top-pick-inline relative rounded-[5px] border-2 bg-surface-white overflow-hidden transition-all duration-200 flex flex-col ${i === 0 ? 'border-green sm:shadow-lg sm:z-10' : 'border-border'}`}>
          {/* Rank badge — fixed height so all cards align */}
          <div class="flex items-center justify-between px-3 pt-3 pb-1 h-10">
            <span class={`inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-[3px] ${i === 0 ? 'bg-green text-white' : 'bg-bg-alt text-text-muted'}`}>
              #{pick.rank} {rankLabels[i]}
            </span>
            {i === 0 && (
              <span class="text-[9px] font-bold uppercase tracking-wider text-green">Editor's Pick</span>
            )}
          </div>

          {/* Wine image */}
          <a href={pick.href} rel="nofollow sponsored" target="_blank" class="block no-underline mx-auto py-3">
            <div class="w-20 h-28 flex items-center justify-center">
              <img
                src={pick.image}
                alt={pick.label}
                class="max-h-28 w-auto object-contain drop-shadow-md"
                loading="lazy"
                decoding="async"
              />
            </div>
          </a>

          {/* Content */}
          <div class="px-3 pb-3 flex flex-col flex-1">
            {/* Stars */}
            <div class="flex items-center justify-center gap-0.5 mb-1.5">
              {Array.from({ length: fullStars }).map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
              {hasHalf && (
                <svg class="w-3.5 h-3.5" viewBox="0 0 20 20">
                  <defs><linearGradient id={`tp-i-${pick.rank}`}><stop offset="50%" stop-color="#fbbf24" /><stop offset="50%" stop-color="#d1d5db" /></linearGradient></defs>
                  <path fill={`url(#tp-i-${pick.rank})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              )}
              {Array.from({ length: emptyStars }).map(() => (
                <svg class="w-3.5 h-3.5 text-gray-300" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
              <span class="text-[10px] text-text-muted ml-1">{stars.toFixed(1)}</span>
            </div>

            {/* Wine name */}
            <h4 class="text-sm font-bold text-primary leading-snug m-0">{pick.label}</h4>

            {/* Meta + CTA pushed to bottom */}
            <div class="mt-auto">
              <div class="text-xs text-text-muted mb-3 mt-2">
                <p class="m-0">{pick.region} · {pick.grape}</p>
                <p class="m-0 mt-1 font-semibold" style="color: var(--color-green-dark);">{pick.score} pts {pick.critic}</p>
              </div>

              <a
                href={pick.href}
                rel="nofollow sponsored"
                target="_blank"
                class="tp-inline-btn block w-full text-center text-white text-xs font-bold py-2.5 no-underline uppercase tracking-wider rounded-[5px] transition-all duration-200"
              >
                Check Price
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <p class="text-[11px] text-text-muted text-center mt-3 italic">Prices vary by state. Click through for your current price.</p>
</div>

<style>
  .top-pick-inline:hover {
    border-color: var(--color-green);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(30, 27, 19, 0.1);
  }
  .tp-inline-btn {
    background-color: #6ab165;
    color: #ffffff !important;
  }
  .tp-inline-btn:hover {
    background-color: #5a9a56;
    color: #ffffff !important;
  }
</style>

---
/**
 * WineQuiz — split-layout interactive quiz, props-based.
 * Pass `wines` from the MDX to match the article's specific bottle list.
 *
 * Wine tag keys:
 *   food:     string[]   — e.g. ['meat', 'pasta', 'cheese', 'just-drinking']
 *   occasion: string[]   — e.g. ['weeknight', 'holiday-party', 'gift', 'big-batch']
 *   style:    string[]   — e.g. ['full-bodied', 'lighter'] OR ['classic', 'adventurous']
 *
 * Scoring: food = 3pts, occasion = 2pts, style = 2pts.
 * Highest score wins; ties broken by lower n (higher on page).
 */

interface WineEntry {
  id: string;
  n: number;
  name: string;
  href: string;
  image: string;
  region: string;
  grape: string;
  score: number;
  critic: string;
  blurb: string;
  tags: { food: string[]; occasion: string[]; style: string[] };
}

interface Question {
  key: 'food' | 'occasion' | 'style';
  label: string;
  heading: string;
  answers: { value: string; label: string }[];
}

interface Props {
  wines: WineEntry[];
  questions?: Question[];
  heroImage?: string;
  heroAlt?: string;
  heroCredit?: string;
  heading?: string;
}

const {
  wines,
  heroImage = '/images/pexels-15103775.webp',
  heroAlt = 'A glass of red wine on a dark backdrop',
  heroCredit = 'Photo by Skyler Ewing on Pexels',
  heading = "Not Sure Which One? Take the 20-Second Quiz",
  questions = [
    {
      key: 'food',
      label: 'Food',
      heading: "What's on the table tonight?",
      answers: [
        { value: 'meat',         label: 'Red meat, burgers, steak' },
        { value: 'pasta',        label: 'Pasta, pizza, anything Italian' },
        { value: 'poultry',      label: 'Chicken, pork, or salmon' },
        { value: 'cheese',       label: 'Cheese, charcuterie, or on its own' },
      ],
    },
    {
      key: 'occasion',
      label: 'Occasion',
      heading: "What's the occasion?",
      answers: [
        { value: 'weeknight',     label: 'Just a regular night in' },
        { value: 'dinner-party',  label: 'Friends coming over for dinner' },
        { value: 'special',       label: 'Date night or celebration' },
        { value: 'gift',          label: 'A gift for someone else' },
      ],
    },
    {
      key: 'style',
      label: 'Style',
      heading: "How adventurous are you feeling?",
      answers: [
        { value: 'classic',      label: 'Give me a safe bet' },
        { value: 'adventurous',  label: 'Surprise me with something new' },
      ],
    },
  ],
} = Astro.props;

const winesJson = JSON.stringify(wines);
const questionsJson = JSON.stringify(questions);
---

<section class="not-prose my-12 wine-quiz" data-wine-quiz>
  <div class="flex items-center gap-4 mb-3">
    <div class="h-px flex-1 bg-border"></div>
    <div class="px-1">
      <h3 class="font-heading font-bold text-primary text-xl sm:text-2xl m-0 tracking-tight">{heading}</h3>
    </div>
    <div class="h-px flex-1 bg-border"></div>
  </div>
  <p class="text-center text-sm text-text-muted italic mb-7">Three quick questions. One matched bottle.</p>

  <div class="quiz-shell relative overflow-hidden rounded-[5px] border-2 border-border bg-surface-white">

    {/* SPLIT LAYOUT */}
    <div class="quiz-layout-split grid grid-cols-1 md:grid-cols-[1fr_1fr]" data-layout="split">

      {/* LEFT: Questions rendered from props */}
      <div class="quiz-left relative px-6 sm:px-10 py-10 md:py-12 flex flex-col">
        {questions.map((q, qi) => (
          <div class="quiz-step" data-step={`q${qi + 1}`} {...(qi > 0 ? { hidden: true } : {})}>
            <div class="flex items-center justify-between mb-5 text-[10px] uppercase tracking-[0.2em] font-bold">
              <span class="text-text-muted">Step {qi + 1} of {questions.length}</span>
              <span class="text-accent">{q.label}</span>
            </div>
            <h4 class="font-heading font-bold text-primary text-xl sm:text-2xl leading-snug mb-6">{q.heading}</h4>
            <div class="flex flex-col gap-2.5 max-w-sm">
              {q.answers.map((a) => (
                <button type="button" class="quiz-pill" data-answer={`${q.key}:${a.value}`}>{a.label}</button>
              ))}
            </div>
            {qi > 0 && (
              <div class="mt-5">
                <button type="button" class="quiz-back text-[10px] uppercase tracking-[0.2em] font-bold text-text-muted cursor-pointer" data-quiz-back>← Back</button>
              </div>
            )}
          </div>
        ))}

        <div class="mt-auto pt-8 flex items-center gap-2" aria-hidden="true">
          {questions.map((_, qi) => (
            <span class="quiz-step-dot" data-step-dot={`q${qi + 1}`}></span>
          ))}
        </div>
      </div>

      {/* RIGHT: Hero */}
      <div class="quiz-right relative overflow-hidden">
        <img src={heroImage} alt={heroAlt} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
        <div class="quiz-right-overlay absolute inset-0"></div>
        <div class="quiz-right-content relative z-10 h-full flex flex-col justify-center px-8 sm:px-12 py-14 md:py-16">
          <span class="inline-block text-[10px] font-bold uppercase tracking-[0.25em] text-white/80 mb-3">Wine Matcher</span>
          <h4 class="font-heading font-bold text-white text-3xl sm:text-4xl leading-tight mb-4 text-balance">Let's find the right bottle for you.</h4>
          <p class="text-sm sm:text-base text-white/85 leading-relaxed max-w-sm">
            Tell us a bit about the occasion and what you're after. We'll match you to one of the bottles on this page.
          </p>
          <span class="sr-only">{heroCredit}</span>
        </div>
      </div>
    </div>

    {/* FULL-WIDTH: Calculating + Result */}
    <div class="quiz-layout-full" data-layout="full" hidden>

      <div class="quiz-step px-6 sm:px-10 py-14" data-step="calculating" hidden>
        <div class="flex flex-col items-center text-center max-w-md mx-auto">
          <div class="quiz-spinner mb-6" aria-hidden="true">
            <svg class="w-12 h-12" viewBox="0 0 50 50">
              <circle cx="25" cy="25" r="20" fill="none" stroke="var(--color-border)" stroke-width="3"></circle>
              <circle class="quiz-spinner-arc" cx="25" cy="25" r="20" fill="none" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round" stroke-dasharray="60 200"></circle>
            </svg>
          </div>
          <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-accent mb-2">Finding Your Match</span>
          <h4 class="font-heading font-bold text-primary text-2xl leading-tight mb-4" data-calc-label>Reading your answers…</h4>
          <div class="flex items-center gap-2 mt-1">
            <span class="quiz-calc-dot" data-calc-dot="0"></span>
            <span class="quiz-calc-dot" data-calc-dot="1"></span>
            <span class="quiz-calc-dot" data-calc-dot="2"></span>
            <span class="quiz-calc-dot" data-calc-dot="3"></span>
          </div>
        </div>
      </div>

      <div class="quiz-step px-6 sm:px-10 py-10" data-step="result" hidden>
        <div class="text-center mb-7">
          <span class="inline-block text-[10px] font-bold uppercase tracking-[0.2em] text-accent mb-2">Your Match</span>
          <h4 class="font-heading font-bold text-primary text-2xl sm:text-3xl leading-tight">Pour this tonight.</h4>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-6 sm:gap-8 items-start bg-surface-low rounded-[5px] border border-border p-6">
          <a class="quiz-result-image-link block mx-auto sm:mx-0 shrink-0" data-result-href target="_blank" rel="nofollow sponsored">
            <div class="w-28 h-40 flex items-center justify-center">
              <img data-result-image alt="" class="max-h-40 w-auto object-contain drop-shadow-md" loading="lazy" decoding="async" />
            </div>
          </a>
          <div class="flex-1">
            <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-text-muted mb-1" data-result-rank></span>
            <h5 class="font-heading font-bold text-primary text-xl leading-snug m-0 mb-2" data-result-name></h5>
            <p class="text-xs text-text-muted m-0 mb-3" data-result-meta></p>
            <div class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider mb-3 px-2 py-1 rounded-[3px] bg-green-light" style="color: var(--color-green-dark);">
              <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              <span data-result-score></span>
            </div>
            <p class="text-sm text-text leading-relaxed m-0 mb-5" data-result-blurb></p>
            <a data-result-href target="_blank" rel="nofollow sponsored" class="quiz-btn-primary inline-flex items-center gap-2 px-6 py-3 rounded-[5px] font-bold text-sm uppercase tracking-wider no-underline transition-all duration-200">
              Check Price on Wine.com
              <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
            </a>
          </div>
        </div>
        <div class="mt-5 pt-5 border-t border-border/70" data-runner-up hidden>
          <p class="text-[10px] font-bold uppercase tracking-[0.15em] text-text-muted mb-2">Also Worth Considering</p>
          <a data-runner-href target="_blank" rel="nofollow sponsored" class="runner-up-card flex items-center gap-4 p-3 rounded-[5px] border border-border bg-surface-white no-underline transition-all duration-200">
            <img data-runner-image alt="" class="w-10 h-14 object-contain shrink-0" loading="lazy" />
            <div class="flex-1 min-w-0">
              <p class="font-heading font-semibold text-primary text-sm leading-snug m-0 truncate" data-runner-name></p>
              <p class="text-xs text-text-muted m-0 mt-0.5" data-runner-meta></p>
            </div>
            <svg class="w-4 h-4 text-text-muted shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
          </a>
        </div>
        <div class="text-center mt-7">
          <button type="button" class="quiz-restart text-xs uppercase tracking-widest font-bold text-text-muted cursor-pointer" data-quiz-restart>↻ Retake the Quiz</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ winesJson, questionsJson }}>
  (function () {
    const wines = JSON.parse(winesJson);
    const questions = JSON.parse(questionsJson);
    const container = document.querySelector('[data-wine-quiz]');
    if (!container) return;

    const stepKeys = questions.map((_, i) => 'q' + (i + 1));
    const splitSteps = new Set(stepKeys);
    const state = { food: null, occasion: null, style: null };
    let currentStep = stepKeys[0];
    let calcTimers = [];

    const calcLabels = [
      'Reading your answers…',
      'Matching style and occasion…',
      'Checking critic scores…',
      'Pouring your recommendation…',
    ];

    function clearCalcTimers() {
      calcTimers.forEach((t) => clearTimeout(t));
      calcTimers = [];
    }

    function runCalculating(onDone) {
      const labelEl = container.querySelector('[data-calc-label]');
      const dots = Array.from(container.querySelectorAll('[data-calc-dot]'));
      dots.forEach((d) => d.classList.remove('is-active', 'is-done'));
      let i = 0;
      const step = () => {
        dots.forEach((d, idx) => {
          d.classList.toggle('is-active', idx === i);
          d.classList.toggle('is-done', idx < i);
        });
        if (labelEl) labelEl.textContent = calcLabels[i];
      };
      step();
      for (let k = 1; k < calcLabels.length; k++) {
        calcTimers.push(setTimeout(() => { i = k; step(); }, 1250 * k));
      }
      calcTimers.push(setTimeout(() => {
        dots.forEach((d) => { d.classList.remove('is-active'); d.classList.add('is-done'); });
        onDone();
      }, 5000));
    }

    function showStep(step, opts) {
      const { scroll = true } = opts || {};
      currentStep = step;
      const split = container.querySelector('[data-layout="split"]');
      const full = container.querySelector('[data-layout="full"]');
      const onSplit = splitSteps.has(step);
      if (split) split.hidden = !onSplit;
      if (full) full.hidden = onSplit;
      container.querySelectorAll('[data-step]').forEach((el) => {
        el.hidden = el.getAttribute('data-step') !== step;
      });
      const order = {};
      stepKeys.forEach((k, i) => { order[k] = i; });
      container.querySelectorAll('[data-step-dot]').forEach((dot) => {
        const dotStep = dot.getAttribute('data-step-dot');
        dot.classList.remove('is-active', 'is-done');
        if (dotStep === step) dot.classList.add('is-active');
        else if ((order[dotStep] ?? 99) < (order[step] ?? 99)) dot.classList.add('is-done');
      });
      if (scroll) {
        const shell = container.querySelector('.quiz-shell');
        if (shell) {
          const rect = shell.getBoundingClientRect();
          if (rect.top < 0 || rect.top > window.innerHeight * 0.4) {
            shell.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      }
    }

    function scoreWines() {
      const results = wines.map((w) => {
        let s = 0;
        if (state.food     && w.tags.food.includes(state.food))         s += 3;
        if (state.occasion && w.tags.occasion.includes(state.occasion)) s += 2;
        if (state.style    && w.tags.style.includes(state.style))       s += 2;
        return { wine: w, score: s };
      });
      results.sort((a, b) => b.score - a.score || a.wine.n - b.wine.n);
      return results;
    }

    function renderResult() {
      const ranked = scoreWines();
      const winner = ranked[0].wine;
      const runner = ranked[1] && ranked[1].score > 0 && ranked[1].wine.id !== winner.id ? ranked[1].wine : null;
      container.querySelector('[data-result-rank]').textContent = '#' + winner.n + ' on our list';
      container.querySelector('[data-result-name]').textContent = winner.name;
      container.querySelector('[data-result-meta]').textContent = winner.region + ' · ' + winner.grape;
      container.querySelector('[data-result-score]').textContent = winner.score + ' pts · ' + winner.critic;
      container.querySelector('[data-result-blurb]').textContent = winner.blurb;
      const img = container.querySelector('[data-result-image]');
      img.src = winner.image; img.alt = winner.name;
      container.querySelectorAll('[data-result-href]').forEach((el) => el.setAttribute('href', winner.href));
      const runnerWrap = container.querySelector('[data-runner-up]');
      if (runner) {
        runnerWrap.hidden = false;
        container.querySelector('[data-runner-name]').textContent = runner.name;
        container.querySelector('[data-runner-meta]').textContent = runner.region + ' · ' + runner.grape + ' · ' + runner.score + ' pts';
        const rImg = container.querySelector('[data-runner-image]');
        rImg.src = runner.image; rImg.alt = runner.name;
        container.querySelector('[data-runner-href]').setAttribute('href', runner.href);
      } else { runnerWrap.hidden = true; }
    }

    container.addEventListener('click', (e) => {
      const target = e.target.closest('button, a');
      if (!target) return;
      if (target.matches('[data-quiz-back]')) {
        const idx = stepKeys.indexOf(currentStep);
        if (idx > 0) showStep(stepKeys[idx - 1]);
        return;
      }
      if (target.matches('[data-quiz-restart]')) {
        clearCalcTimers();
        state.food = null; state.occasion = null; state.style = null;
        showStep(stepKeys[0]);
        return;
      }
      const answer = target.getAttribute('data-answer');
      if (answer) {
        const [key, value] = answer.split(':');
        state[key] = value;
        const q = questions.find((q) => q.key === key);
        const qi = questions.indexOf(q);
        if (qi < questions.length - 1) {
          showStep(stepKeys[qi + 1]);
        } else {
          showStep('calculating');
          clearCalcTimers();
          runCalculating(() => { renderResult(); showStep('result'); });
        }
      }
    });

    showStep(stepKeys[0], { scroll: false });
  })();
</script>

<style>
  .quiz-shell { box-shadow: 0 4px 16px rgba(30, 27, 19, 0.06); }
  .quiz-right { min-height: 320px; }
  .quiz-right-overlay { background: linear-gradient(135deg, rgba(87, 0, 19, 0.78) 0%, rgba(30, 10, 15, 0.72) 100%); }
  @media (min-width: 768px) { .quiz-right { min-height: 100%; } }
  .quiz-pill {
    display: block; width: 100%; text-align: center;
    padding: 0.875rem 1.25rem; border-radius: 5px;
    border: 2px solid var(--color-border); background-color: var(--color-surface-white);
    font-family: var(--font-heading); font-weight: 600; font-size: 0.95rem;
    color: var(--color-primary); cursor: pointer; transition: all 0.2s ease; line-height: 1.25;
  }
  .quiz-pill:hover { border-color: var(--color-primary); background-color: var(--color-surface-high); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(87, 0, 19, 0.1); }
  .quiz-pill:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }
  .quiz-pill:active { transform: translateY(0); }
  .quiz-step-dot { display: inline-block; width: 10px; height: 10px; border-radius: 9999px; background-color: var(--color-border); transition: background-color 0.25s ease, transform 0.25s ease; }
  .quiz-step-dot.is-active { background-color: var(--color-accent); transform: scale(1.25); }
  .quiz-step-dot.is-done { background-color: var(--color-primary); }
  .quiz-back:hover, .quiz-restart:hover { color: var(--color-accent); }
  .quiz-btn-primary { background-color: var(--color-accent); color: #ffffff !important; border: 2px solid var(--color-accent); }
  .quiz-btn-primary:hover { background-color: var(--color-accent-hover); border-color: var(--color-accent-hover); transform: translateY(-1px); }
  .quiz-spinner svg { display: block; }
  .quiz-spinner-arc { transform-origin: 25px 25px; animation: quiz-spin 1.1s linear infinite; }
  @keyframes quiz-spin { to { transform: rotate(360deg); } }
  .quiz-calc-dot { display: inline-block; width: 8px; height: 8px; border-radius: 9999px; background-color: var(--color-border); transition: background-color 0.25s ease, transform 0.25s ease; }
  .quiz-calc-dot.is-active { background-color: var(--color-accent); transform: scale(1.35); }
  .quiz-calc-dot.is-done { background-color: var(--color-primary); }
  .runner-up-card:hover { border-color: var(--color-green); background-color: var(--color-surface-low); transform: translateY(-1px); }
  .text-balance { text-wrap: balance; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
  @media (prefers-reduced-motion: reduce) {
    .quiz-pill, .quiz-btn-primary, .runner-up-card, .quiz-step-dot, .quiz-calc-dot { transition: none !important; }
    .quiz-pill:hover, .quiz-btn-primary:hover, .runner-up-card:hover { transform: none; }
    .quiz-spinner-arc { animation: none; }
  }
</style>

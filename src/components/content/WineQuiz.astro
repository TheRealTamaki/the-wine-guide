---
/**
 * WineQuiz — split-layout interactive quiz.
 * Questions live on the left, a persistent hero (copy + wine glass image) on the right.
 * On the last answer, a 5-second "finding your match" screen shows, then reveals the matched bottle.
 *
 * Scoring: food match = 3pts, occasion = 2pts, style = 2pts.
 * Highest score wins; on tie, lower wine number (higher on page) breaks it.
 */

const wines = [
  {
    id: 'jlohr', n: 1,
    name: 'J. Lohr Seven Oaks Cabernet Sauvignon 2023',
    href: 'https://www.wine.com/product/j-lohr-estates-seven-oaks-cabernet-sauvignon-2023/4124622',

  'sauv:mozz':   { score: 86, why: 'Crisp herbaceous wine plus milky cheese equals a caprese in liquid form.' },
  'sauv:humb':   { score: 90, why: 'Grapefruit and goat’s lemon, with a thread of grass between them.' },


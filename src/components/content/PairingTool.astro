  'rose:taleg':  { score: 84, why: 'Strawberry and washed rind. Fruit cuts the funk just enough.' },
};

type Wine = typeof WINES[number];
type Cheese = typeof CHEESES[number];

function pairScore(wine: Wine, cheese: Cheese) {
  const key = `${wine.id}:${cheese.id}`;
  if (ANCHORS[key]) return ANCHORS[key];

  let score = 50;
  const bodyDiff = Math.abs(wine.body - cheese.body);
  score += (3 - Math.min(3, bodyDiff)) * 6;
  const overlap = wine.tags.filter((t) => cheese.tags.includes(t)).length;
  score += overlap * 5;

  const wt = new Set(wine.tags), ct = new Set(cheese.tags);
  if (wt.has('sweet') && (ct.has('blue') || ct.has('salty'))) score += 18;
  if (wt.has('acid') && (ct.has('creamy') || ct.has('rich'))) score += 8;
  if (wt.has('acid') && ct.has('fresh')) score += 10;
  if (wt.has('tannic') && ct.has('rich')) score += 10;
  if (wt.has('tannic') && ct.has('fresh')) score -= 12;
  if (wt.has('effervescent') && ct.has('creamy')) score += 10;
  if (wt.has('effervescent') && ct.has('rich')) score += 6;
  if (wine.cat === 'red' && ct.has('fresh')) score -= 10;
  if (wine.cat === 'red' && ct.has('blue') && !wt.has('sweet')) score -= 8;
  if (wt.has('aromatic') && ct.has('funk-strong')) score += 8;

  if (wine.region.split(' ')[0] === cheese.region.split(' ')[0]) score += 4;
  score = Math.max(38, Math.min(94, Math.round(score)));

  let why: string;
  if (wt.has('sweet') && ct.has('blue')) why = 'Sweet wine and blue cheese is a universal rule. Sugar tames salt.';
  else if (wt.has('acid') && ct.has('creamy')) why = 'Acidity cuts richness and keeps every bite feeling fresh.';
  else if (wt.has('tannic') && ct.has('rich')) why = 'Tannin needs fat to soften, and this cheese has it in spades.';
  else if (wt.has('effervescent')) why = 'Bubbles scrub the palate clean between bites. The great resetter.';
  else if (bodyDiff <= 1) why = 'Matched body and intensity. Neither one shouts over the other.';
  else if (overlap > 0) {
    const shared = wine.tags.find((t) => cheese.tags.includes(t));
    why = `Both share a ${shared} character that ties them together.`;
  }
  else why = 'A reliable middle-ground pairing. Pleasant, balanced, no fireworks.';

  return { score, why };
}

function topPairings(item: Wine | Cheese, list: (Wine | Cheese)[], n = 4) {
  const isWine = 'cat' in item;
  const scored = list.map((other) => {
    const { score, why } = isWine
      ? pairScore(item as Wine, other as Cheese)
      : pairScore(other as Wine, item as Cheese);
    return { item: other, score, why };
  });
  scored.sort((a, b) => b.score - a.score);
  return scored.slice(0, n);
}

const catLabels: Record<string, string> = {
  red: 'Reds', white: 'Whites', rose: 'Rosé', sparkling: 'Sparkling', dessert: 'Dessert & Fortified',
};
const catLabel = (c: string) => catLabels[c] || c;

// ─── Server-side initial render ─────────────────────────────────────────────
const initialWine = WINES.find((w) => w.id === 'pinot')!;
const initialTop = topPairings(initialWine, CHEESES, 4);

function dotRow(filled: number, total = 5) {
  return '●'.repeat(filled) + '○'.repeat(total - filled);
}

function starsHTML(score: number) {
  const filled = Math.round(score / 20);
  const empty = 5 - filled;
  return `<span class="pt-stars-row">${'★'.repeat(filled)}<span class="pt-stars-empty">${'★'.repeat(empty)}</span></span><span class="pt-stars-label">${score}/100</span>`;
}

// Group helpers for server picker
const wineGroups: Record<string, Wine[]> = {};
WINES.forEach((w) => {
  const k = catLabel(w.cat);
  (wineGroups[k] = wineGroups[k] || []).push(w);
});

const dataBlob = JSON.stringify({ WINES, CHEESES, ANCHORS });
---

<section class="pairing-tool" data-component="pairing-tool" data-mode="wine" data-wine="pinot" data-cheese="comte" data-cat="red">
  <header class="pt-header">
    <div class="pt-header-text">
      <p class="pt-eyebrow">Try it</p>
      <h2 class="pt-title">Find Your Match</h2>
      <p class="pt-subtitle">Pick a wine, get the four cheeses it loves. Or flip it: pick a cheese, get the wines that meet it best.</p>
    </div>
    <div class="pt-header-controls">
      <div class="pt-toggle" role="tablist" aria-label="Pairing mode">
        <button class="pt-toggle-btn is-active" data-mode-btn="wine" role="tab" aria-selected="true">
          <span class="pt-toggle-eyebrow">I have</span>
          <span class="pt-toggle-label">Wine</span>
        </button>
        <button class="pt-toggle-btn" data-mode-btn="cheese" role="tab" aria-selected="false">
          <span class="pt-toggle-eyebrow">I have</span>
          <span class="pt-toggle-label">Cheese</span>
        </button>
      </div>
      <label class="pt-veg">
        <input type="checkbox" data-veg-toggle />
        <span>Vegetarian rennet only</span>
      </label>
    </div>
  </header>

  <div class="pt-grid">
    <aside class="pt-picker" data-picker>
      <p class="pt-picker-title">Choose your wine</p>
      {Object.entries(wineGroups).map(([group, list]) => (
        <div class="pt-group" data-group>
          <p class="pt-group-label">{group}</p>
          {list.map((w) => (
            <button
              class={`pt-pick-btn${w.id === 'pinot' ? ' is-selected' : ''}`}
              data-pick-id={w.id}
              type="button"
            >
              <span class="pt-pick-name">{w.name}</span>
              <span class="pt-pick-region">{w.region}</span>
            </button>
          ))}
        </div>
      ))}
    </aside>

    <div class="pt-dossier" data-dossier>
      <article class="pt-hero">
        <div class="pt-hero-main">
          <p class="pt-hero-eyebrow" data-hero-eyebrow>{catLabel(initialWine.cat)} · {initialWine.region}</p>
          <h3 class="pt-hero-name" data-hero-name>{initialWine.name}</h3>
          <p class="pt-hero-blurb" data-hero-blurb>{initialWine.blurb}</p>
        </div>
        <dl class="pt-hero-stats" data-hero-stats>
          <div><dt>Body</dt><dd>{dotRow(initialWine.body)}</dd></div>
          <div><dt>Intensity</dt><dd>{dotRow(initialWine.intensity)}</dd></div>
          <div><dt>Serve</dt><dd>{initialWine.serve}</dd></div>
        </dl>
        <p class="pt-hero-notes" data-hero-notes><span>Tasting notes.</span> {initialWine.notes}</p>
      </article>

      <div class="pt-section-title">
        <span class="pt-section-italic">Pours best with</span>
        <span class="pt-rule"></span>
        <span class="pt-section-count" data-pairing-count>4 suggestions</span>
      </div>

      <ol class="pt-pairings" data-pairings>
        {initialTop.map((p, idx) => {
          const c = p.item as Cheese;
          return (
            <li class="pt-pairing">
              <span class={`pt-rank pt-rank-${idx + 1}`}>{['My top pick', '2nd pick', '3rd pick', '4th pick'][idx] || `${idx + 1}th pick`}</span>
              <div class="pt-pairing-body">
                <p class="pt-pairing-eyebrow">{c.style} · {c.region}</p>
                <h4 class="pt-pairing-name">{c.name}</h4>
                <p class="pt-pairing-why">"{p.why}"</p>
                <p class="pt-pairing-notes">{c.notes}</p>
                <button class="pt-board-btn" data-board-add={c.id} type="button">+ add to board</button>
              </div>
              <div class="pt-score" set:html={starsHTML(p.score)}></div>
            </li>
          );
        })}
      </ol>
    </div>
  </div>

  <div class="pt-board" data-board>
    <div class="pt-board-empty" data-board-empty>
      <p>Build a board around <strong data-board-empty-name>{initialWine.name}</strong>. Add cheeses from the list above.</p>
    </div>
    <div class="pt-board-full" data-board-full hidden>
      <div class="pt-board-head">
        <div>
          <p class="pt-board-eyebrow">Your board</p>
          <p class="pt-board-name">A board for <span data-board-wine-name>{initialWine.name}</span></p>
        </div>
        <button class="pt-board-clear" data-board-clear type="button">Clear</button>
      </div>
      <ul class="pt-board-list" data-board-list></ul>
      <p class="pt-board-tip">
        <span class="pt-tip-mark">Sommelier tip.</span>
        Serve cheeses 30 minutes from the fridge, mildest to strongest. Open the wine 20 minutes before pouring.
      </p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ dataBlob }}>
  (function () {
    const root = document.querySelector('[data-component="pairing-tool"]');
    if (!root) return;
    const { WINES, CHEESES, ANCHORS } = JSON.parse(dataBlob);

    const catLabels = { red: 'Reds', white: 'Whites', rose: 'Rosé', sparkling: 'Sparkling', dessert: 'Dessert & Fortified' };
    const catLabel = (c) => catLabels[c] || c;

    function pairScore(wine, cheese) {
      const key = `${wine.id}:${cheese.id}`;
      if (ANCHORS[key]) return ANCHORS[key];
      let score = 50;
      const bodyDiff = Math.abs(wine.body - cheese.body);
      score += (3 - Math.min(3, bodyDiff)) * 6;
      const overlap = wine.tags.filter((t) => cheese.tags.includes(t)).length;
      score += overlap * 5;
      const wt = new Set(wine.tags), ct = new Set(cheese.tags);
      if (wt.has('sweet') && (ct.has('blue') || ct.has('salty'))) score += 18;
      if (wt.has('acid') && (ct.has('creamy') || ct.has('rich'))) score += 8;
      if (wt.has('acid') && ct.has('fresh')) score += 10;
      if (wt.has('tannic') && ct.has('rich')) score += 10;
      if (wt.has('tannic') && ct.has('fresh')) score -= 12;
      if (wt.has('effervescent') && ct.has('creamy')) score += 10;
      if (wt.has('effervescent') && ct.has('rich')) score += 6;
      if (wine.cat === 'red' && ct.has('fresh')) score -= 10;
      if (wine.cat === 'red' && ct.has('blue') && !wt.has('sweet')) score -= 8;
      if (wt.has('aromatic') && ct.has('funk-strong')) score += 8;
      if (wine.region.split(' ')[0] === cheese.region.split(' ')[0]) score += 4;
      score = Math.max(38, Math.min(94, Math.round(score)));
      let why;
      if (wt.has('sweet') && ct.has('blue')) why = 'Sweet wine and blue cheese is a universal rule. Sugar tames salt.';
      else if (wt.has('acid') && ct.has('creamy')) why = 'Acidity cuts richness and keeps every bite feeling fresh.';
      else if (wt.has('tannic') && ct.has('rich')) why = 'Tannin needs fat to soften, and this cheese has it in spades.';
      else if (wt.has('effervescent')) why = 'Bubbles scrub the palate clean between bites. The great resetter.';
      else if (bodyDiff <= 1) why = 'Matched body and intensity. Neither one shouts over the other.';
      else if (overlap > 0) {
        const shared = wine.tags.find((t) => cheese.tags.includes(t));
        why = 'Both share a ' + shared + ' character that ties them together.';
      } else why = 'A reliable middle-ground pairing. Pleasant, balanced, no fireworks.';
      return { score, why };
    }

    function topPairings(item, list, n) {
      const isWine = 'cat' in item;
      const scored = list.map((other) => {
        const r = isWine ? pairScore(item, other) : pairScore(other, item);
        return { item: other, score: r.score, why: r.why };
      });
      scored.sort((a, b) => b.score - a.score);
      return scored.slice(0, n);
    }

    function dotRow(filled, total) {
      total = total || 5;
      return '●'.repeat(filled) + '○'.repeat(total - filled);
    }

    function escapeHTML(s) {
      return String(s).replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));
    }

    function starsHTML(score) {
      const filled = Math.round(score / 20);
      const empty = 5 - filled;
      return '<span class="pt-stars-row">' + '★'.repeat(filled) +
        '<span class="pt-stars-empty">' + '★'.repeat(empty) + '</span></span>' +
        '<span class="pt-stars-label">' + score + '/100</span>';
    }

    // ─── State ───
    const state = {
      mode: root.dataset.mode || 'wine',
      wineId: root.dataset.wine || 'pinot',
      cheeseId: root.dataset.cheese || 'comte',
      veg: false,
      board: [],
    };

    // ─── DOM refs ───
    const $ = (sel) => root.querySelector(sel);
    const $$ = (sel) => Array.from(root.querySelectorAll(sel));
    const picker = $('[data-picker]');
    const dossier = $('[data-dossier]');
    const heroEyebrow = $('[data-hero-eyebrow]');
    const heroName = $('[data-hero-name]');
    const heroBlurb = $('[data-hero-blurb]');
    const heroStats = $('[data-hero-stats]');
    const heroNotes = $('[data-hero-notes]');
    const pairingsList = $('[data-pairings]');
    const pairingCount = $('[data-pairing-count]');
    const board = $('[data-board]');
    const boardEmpty = $('[data-board-empty]');
    const boardFull = $('[data-board-full]');
    const boardEmptyName = $('[data-board-empty-name]');
    const boardWineName = $('[data-board-wine-name]');
    const boardList = $('[data-board-list]');

    // ─── Render picker ───
    function renderPicker() {
      const items = state.mode === 'wine' ? WINES : CHEESES;
      const filtered = state.mode === 'cheese' && state.veg ? items.filter((i) => i.veg) : items;
      const groups = {};
      filtered.forEach((i) => {
        const k = state.mode === 'wine' ? catLabel(i.cat) : i.style;
        (groups[k] = groups[k] || []).push(i);
      });
      const selectedId = state.mode === 'wine' ? state.wineId : state.cheeseId;
      let html = '<p class="pt-picker-title">Choose your ' + state.mode + '</p>';
      Object.entries(groups).forEach(([group, list]) => {
        html += '<div class="pt-group">';
        html += '<p class="pt-group-label">' + escapeHTML(group) + '</p>';
        list.forEach((i) => {
          const sel = i.id === selectedId ? ' is-selected' : '';
          html += '<button class="pt-pick-btn' + sel + '" data-pick-id="' + i.id + '" type="button">';
          html += '<span class="pt-pick-name">' + escapeHTML(i.name) + '</span>';
          html += '<span class="pt-pick-region">' + escapeHTML(i.region) + '</span>';
          html += '</button>';
        });
        html += '</div>';
      });
      picker.innerHTML = html;
    }

    // ─── Render dossier ───
    function renderDossier() {
      const source = state.mode === 'wine'
        ? WINES.find((w) => w.id === state.wineId)
        : CHEESES.find((c) => c.id === state.cheeseId);
      if (!source) return;

      heroEyebrow.textContent = state.mode === 'wine'
        ? catLabel(source.cat) + ' · ' + source.region
        : source.style + ' · ' + source.region;
      heroName.textContent = source.name;
      heroBlurb.textContent = source.blurb;

      let statsHTML = '';
      statsHTML += '<div><dt>Body</dt><dd>' + dotRow(source.body) + '</dd></div>';
      statsHTML += '<div><dt>Intensity</dt><dd>' + dotRow(source.intensity) + '</dd></div>';
      if (state.mode === 'wine') {
        statsHTML += '<div><dt>Serve</dt><dd>' + escapeHTML(source.serve) + '</dd></div>';
      } else {
        statsHTML += '<div><dt>Milk</dt><dd>' + escapeHTML(source.milk) + '</dd></div>';
        statsHTML += '<div><dt>Aged</dt><dd>' + escapeHTML(source.age) + '</dd></div>';
      }
      heroStats.innerHTML = statsHTML;
      heroNotes.innerHTML = '<span>Tasting notes.</span> ' + escapeHTML(source.notes);

      const otherList = state.mode === 'wine' ? CHEESES : WINES;
      const filteredOthers = state.mode === 'wine' && state.veg ? otherList.filter((c) => c.veg) : otherList;
      const top = topPairings(source, filteredOthers, 4);
      pairingCount.textContent = top.length + ' suggestions';

      let pHTML = '';
      top.forEach((p, idx) => {
        const o = p.item;
        const eyebrow = state.mode === 'wine'
          ? escapeHTML(o.style) + ' · ' + escapeHTML(o.region)
          : catLabel(o.cat) + ' · ' + escapeHTML(o.region);
        pHTML += '<li class="pt-pairing">';
        const rankLabel = ['My top pick', '2nd pick', '3rd pick', '4th pick'][idx] || ((idx + 1) + 'th pick');
        pHTML += '<span class="pt-rank pt-rank-' + (idx + 1) + '">' + rankLabel + '</span>';
        pHTML += '<div class="pt-pairing-body">';
        pHTML += '<p class="pt-pairing-eyebrow">' + eyebrow + '</p>';
        pHTML += '<h4 class="pt-pairing-name">' + escapeHTML(o.name) + '</h4>';
        pHTML += '<p class="pt-pairing-why">"' + escapeHTML(p.why) + '"</p>';
        pHTML += '<p class="pt-pairing-notes">' + escapeHTML(o.notes) + '</p>';
        if (state.mode === 'wine') {
          const onBoard = state.board.indexOf(o.id) !== -1;
          pHTML += '<button class="pt-board-btn' + (onBoard ? ' is-on' : '') + '" data-board-add="' + o.id + '" type="button">';
          pHTML += onBoard ? '✓ on the board' : '+ add to board';
          pHTML += '</button>';
        }
        pHTML += '</div>';
        pHTML += '<div class="pt-score">' + starsHTML(p.score) + '</div>';
        pHTML += '</li>';
      });
      pairingsList.innerHTML = pHTML;
    }

    // ─── Render board ───
    function renderBoard() {
      if (state.mode !== 'wine') {
        board.hidden = true;
        return;
      }
      board.hidden = false;
      const wine = WINES.find((w) => w.id === state.wineId);
      if (!wine) return;
      if (state.board.length === 0) {
        boardEmpty.hidden = false;
        boardFull.hidden = true;
        boardEmptyName.textContent = wine.name;
        return;
      }
      boardEmpty.hidden = true;
      boardFull.hidden = false;
      boardWineName.textContent = wine.name;
      const cheeses = state.board.map((id) => CHEESES.find((c) => c.id === id)).filter(Boolean);
      let html = '';
      cheeses.forEach((c) => {
        html += '<li class="pt-board-item">';
        html += '<div><p class="pt-board-item-name">' + escapeHTML(c.name) + '</p>';
        html += '<p class="pt-board-item-style">' + escapeHTML(c.style) + '</p></div>';
        html += '<button class="pt-board-remove" data-board-remove="' + c.id + '" type="button" aria-label="Remove">×</button>';
        html += '</li>';
      });
      boardList.innerHTML = html;
    }

    function syncCat() {
      if (state.mode === 'wine') {
        const w = WINES.find((x) => x.id === state.wineId);
        root.dataset.cat = w ? w.cat : 'red';
      } else {
        root.dataset.cat = 'cheese';
      }
    }

    function renderAll() {
      syncCat();
      renderPicker();
      renderDossier();
      renderBoard();
    }

    // ─── Events ───
    root.addEventListener('click', (e) => {
      const t = e.target.closest('[data-mode-btn], [data-pick-id], [data-board-add], [data-board-remove], [data-board-clear]');
      if (!t) return;

      if (t.dataset.modeBtn) {
        state.mode = t.dataset.modeBtn;
        $$('[data-mode-btn]').forEach((b) => {
          const active = b.dataset.modeBtn === state.mode;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        renderAll();
        return;
      }
      if (t.dataset.pickId) {
        if (state.mode === 'wine') state.wineId = t.dataset.pickId;
        else state.cheeseId = t.dataset.pickId;
        renderAll();
        return;
      }
      if (t.dataset.boardAdd) {
        const id = t.dataset.boardAdd;
        if (state.board.indexOf(id) !== -1) {
          state.board = state.board.filter((x) => x !== id);
        } else {
          state.board.push(id);
        }
        renderDossier();
        renderBoard();
        return;
      }
      if (t.dataset.boardRemove) {
        state.board = state.board.filter((x) => x !== t.dataset.boardRemove);
        renderDossier();
        renderBoard();
        return;
      }
      if (t.hasAttribute('data-board-clear')) {
        state.board = [];
        renderDossier();
        renderBoard();
        return;
      }
    });

    const vegInput = root.querySelector('[data-veg-toggle]');
    if (vegInput) {
      vegInput.addEventListener('change', (e) => {
        state.veg = !!e.target.checked;
        renderAll();
      });
    }
  })();
</script>


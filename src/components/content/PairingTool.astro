  'pinot:gruy':  { score: 92, why: 'Earthy Pinot answers Gruyère’s broth. Alpine in a glass.' },
  'pinot:humb':  { score: 88, why: 'Forest-floor Pinot meets Humboldt’s ash and lemon. A woodland walk.' },
  'pinot:epoi':  { score: 90, why: 'Burgundy’s grape meets Burgundy’s cheese. They were raised together.' },

  'chard:brie':  { score: 92, why: 'Buttery Chardonnay echoes Brie’s cream. A pillow on a pillow.' },
  'chard:gruy':  { score: 90, why: 'Oak in the wine, oak in the cellar. They share a vocabulary.' },
  'chard:comte': { score: 91, why: 'Both nutty, both rich, both patient. A long, generous pairing.' },


---
interface Props {
  category: string;
  class?: string;
}

const { category, class: className = '' } = Astro.props;

const label = category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---

<span class={`inline-block text-xs font-semibold uppercase tracking-wider text-accent bg-accent-light px-2.5 py-1 rounded-full ${className}`}>
  {label}
</span>

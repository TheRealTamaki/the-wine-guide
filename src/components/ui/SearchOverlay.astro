---
---

<div id="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div id="search-backdrop"></div>
  <div id="search-panel">
    <div id="search-input-row">
      <svg id="search-icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search guides, grapes, regions…"
        autocomplete="off"
        spellcheck="false"
      />
      <button id="search-close" aria-label="Close search">Esc</button>
    </div>
    <ul id="search-results" role="listbox" aria-label="Search results"></ul>
    <p id="search-empty" hidden>No results for that. Try a grape, region, or wine style.</p>
  </div>
</div>

<script>
  const CATEGORY_LABELS: Record<string, string> = {
    'best-wines': 'Best Wines',
    'wine-basics': 'Wine Basics',
    'wine-tools': 'Wine Tools',
    'gift-guides': 'Gift Guides',
    'compare': 'Comparisons',
    'grapes': 'Grapes',
    'regions': 'Regions',
    'types-of-wine': 'Wine Types',
    'food-wine-pairing': 'Food Pairing',
    'pairing': 'Pairing',
    'products': 'Products',
    'wine-glossary': 'Glossary',
  };

  type Article = { title: string; description: string; category: string; url: string };

  let index: Article[] = [];
  let activeIdx = -1;

  const overlay  = document.getElementById('search-overlay')!;
  const input    = document.getElementById('search-input') as HTMLInputElement;
  const results  = document.getElementById('search-results')!;
  const empty    = document.getElementById('search-empty')!;
  const backdrop = document.getElementById('search-backdrop')!;
  const closeBtn = document.getElementById('search-close')!;

  async function loadIndex() {
    if (index.length) return;
    try {
      const res = await fetch('/search-index.json');
      index = await res.json();
    } catch {
      index = [];
    }
  }

  function score(article: Article, q: string): number {
    const t = article.title.toLowerCase();
    const d = (article.description ?? '').toLowerCase();
    const c = (CATEGORY_LABELS[article.category] ?? article.category).toLowerCase();
    if (t.startsWith(q)) return 3;
    if (t.includes(q)) return 2;
    if (d.includes(q) || c.includes(q)) return 1;
    return 0;
  }

  function search(q: string) {
    const query = q.trim().toLowerCase();
    results.innerHTML = '';
    activeIdx = -1;

    if (!query) {
      empty.hidden = true;
      return;
    }

    const hits = index
      .map((a) => ({ article: a, s: score(a, query) }))
      .filter((x) => x.s > 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 8)
      .map((x) => x.article);

    if (!hits.length) {
      empty.hidden = false;
      return;
    }

    empty.hidden = true;
    hits.forEach((article, i) => {
      const li = document.createElement('li');
      li.setAttribute('role', 'option');
      li.setAttribute('data-idx', String(i));
      li.innerHTML = `
        <a href="${article.url}" tabindex="-1">
          <span class="sr-cat">${CATEGORY_LABELS[article.category] ?? article.category}</span>
          <span class="sr-title">${article.title}</span>
          <span class="sr-desc">${article.description ?? ''}</span>
        </a>`;
      li.addEventListener('mouseenter', () => setActive(i));
      results.appendChild(li);
    });
  }

  function setActive(idx: number) {
    const items = results.querySelectorAll('li');
    items.forEach((li, i) => li.classList.toggle('is-active', i === idx));
    activeIdx = idx;
  }

  function open() {
    loadIndex();
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => input.focus());
  }

  function close() {
    overlay.hidden = true;
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '';
    empty.hidden = true;
    activeIdx = -1;
  }

  input.addEventListener('input', () => search(input.value));

  input.addEventListener('keydown', (e) => {
    const items = results.querySelectorAll('li');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, items.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIdx - 1, 0));
    } else if (e.key === 'Enter') {
      const active = results.querySelector('li.is-active a') as HTMLAnchorElement | null;
      if (active) { close(); active.click(); }
    } else if (e.key === 'Escape') {
      close();
    }
  });

  backdrop.addEventListener('click', close);
  closeBtn.addEventListener('click', close);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay.hidden ? open() : close();
    }
    if (e.key === 'Escape' && !overlay.hidden) close();
  });

  document.addEventListener('open-search', open);
</script>

<style>
  #search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
    padding-left: 16px;
    padding-right: 16px;
  }

  #search-overlay[hidden] { display: none; }

  #search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 12, 8, 0.55);
    backdrop-filter: blur(2px);
  }

  #search-panel {
    position: relative;
    width: 100%;
    max-width: 620px;
    background: #f4efe6;
    border: 1.5px solid #1f1f1f;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0,0,0,0.28);
  }

  #search-input-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 18px;
    border-bottom: 1.5px solid #1f1f1f;
  }

  #search-icon {
    flex-shrink: 0;
    color: #3a3530;
    opacity: 0.6;
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px;
    color: #1f1f1f;
    padding: 18px 0;
    letter-spacing: 0.01em;
  }

  #search-input::placeholder {
    color: #3a3530;
    opacity: 0.5;
  }

  #search-input::-webkit-search-cancel-button { display: none; }

  #search-close {
    flex-shrink: 0;
    background: rgba(31, 31, 31, 0.08);
    border: 1px solid rgba(31, 31, 31, 0.18);
    border-radius: 3px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #3a3530;
    padding: 3px 7px;
    cursor: pointer;
    opacity: 0.7;
  }

  #search-results {
    list-style: none;
    margin: 0;
    padding: 6px 0;
    max-height: 420px;
    overflow-y: auto;
  }

  #search-results li a {
    display: block;
    padding: 12px 18px;
    text-decoration: none;
    cursor: pointer;
  }

  #search-results li.is-active a,
  #search-results li a:hover {
    background: rgba(138, 74, 47, 0.08);
  }

  .sr-cat {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8a4a2f;
    margin-bottom: 3px;
  }

  .sr-title {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #1f1f1f;
    line-height: 1.3;
    margin-bottom: 2px;
  }

  .sr-desc {
    display: block;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 12px;
    color: #3a3530;
    opacity: 0.7;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  #search-empty {
    padding: 20px 18px;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    color: #3a3530;
    opacity: 0.65;
    margin: 0;
  }

  #search-empty[hidden] { display: none; }
</style>

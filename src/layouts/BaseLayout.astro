---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  publishDate?: Date;
  modifiedDate?: Date;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage,
  publishDate,
  modifiedDate,
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head
      {title}
      {description}
      {canonicalUrl}
      {ogImage}
      {publishDate}
      {modifiedDate}
      {type}
      {noindex}
    />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body class="bg-bg text-text font-body selection:bg-accent-light selection:text-primary">
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

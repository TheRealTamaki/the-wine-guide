---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import RelatedArticles from '../components/ui/RelatedArticles.astro';
import AffiliateDisclosure from '../components/ui/AffiliateDisclosure.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  headings?: { depth: number; slug: string; text: string }[];
}

const { article, headings = [] } = Astro.props;
const { title, description, publishDate, modifiedDate, ogImage, affiliateDisclosure, relatedArticles } = article.data;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Comparisons', href: '/compare/' },
  { label: title },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (modifiedDate ?? publishDate).toISOString(),
  author: { '@type': 'Organization', name: 'The Wine Guide' },
};
---

<BaseLayout
  {title}
  {description}
  {ogImage}
  publishDate={publishDate}
  modifiedDate={modifiedDate}
  type="article"
  {schema}
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mt-6 max-w-[42rem]">
      <span class="inline-block text-xs font-semibold uppercase tracking-wider text-accent mb-3">
        Comparison
      </span>
      <h1 class="text-[2rem] font-heading font-bold text-primary leading-tight">{title}</h1>
      <p class="mt-4 text-lg text-secondary leading-relaxed">{description}</p>
      <div class="mt-4 text-sm text-text-muted">
        <time datetime={publishDate.toISOString()}>
          {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    {affiliateDisclosure && <AffiliateDisclosure class="mt-6" />}

    <!-- Full-width comparison content -->
    <div class="mt-8 prose max-w-none">
      <slot />
    </div>

    {relatedArticles.length > 0 && (
      <div class="mt-12 pt-8 border-t border-border">
        <h2 class="text-xl font-heading font-semibold text-primary mb-6">Related Guides</h2>
        <RelatedArticles slugs={relatedArticles} />
      </div>
    )}
  </div>
</BaseLayout>

---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import TableOfContents from '../components/ui/TableOfContents.astro';
import RelatedArticles from '../components/ui/RelatedArticles.astro';
import AffiliateDisclosure from '../components/ui/AffiliateDisclosure.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  headings?: { depth: number; slug: string; text: string }[];
}

const { article, headings = [] } = Astro.props;
const { title, description, category, publishDate, modifiedDate, ogImage, affiliateDisclosure, relatedArticles } = article.data;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()), href: `/${category}/` },
  { label: title },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (modifiedDate ?? publishDate).toISOString(),
  author: { '@type': 'Organization', name: 'The Wine Guide' },
  publisher: { '@type': 'Organization', name: 'The Wine Guide', url: 'https://thewine.guide' },
};

const readingTime = Math.ceil((article.body?.length ?? 0) / 1400);
---

<BaseLayout
  {title}
  {description}
  {ogImage}
  publishDate={publishDate}
  modifiedDate={modifiedDate}
  type="article"
  {schema}
>
  <div class="max-w-7xl mx-auto px-6 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <!-- Header -->
    <header class="mb-12 mt-8">
      <div class="flex items-center gap-2 mb-4">
        <CategoryBadge {category} />
        {readingTime > 0 && (
          <span class="text-text-muted text-sm uppercase tracking-widest">{readingTime} min read</span>
        )}
      </div>
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-primary leading-tight mb-4">
        {title}
      </h1>
      <p class="text-xl text-text-muted max-w-3xl leading-relaxed">
        {description}
      </p>
      <div class="mt-4 text-sm text-text-muted">
        <time datetime={publishDate.toISOString()}>
          {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    <div class="lg:grid lg:grid-cols-[1fr_18rem] lg:gap-12">
      <!-- Main content -->
      <article>
        {affiliateDisclosure && <AffiliateDisclosure class="mb-6" />}

        <div class="prose">
          <slot />
        </div>

        {relatedArticles.length > 0 && (
          <div class="mt-16 pt-8 border-t border-border">
            <h2 class="text-2xl font-heading font-bold text-primary mb-8">Keep Reading</h2>
            <RelatedArticles slugs={relatedArticles} />
          </div>
        )}
      </article>

      <!-- TOC sidebar -->
      {headings.length > 2 && (
        <aside class="hidden lg:block">
          <div class="sticky top-28 bg-bg-alt rounded-[var(--twg-radius-lg)] p-8">
            <TableOfContents {headings} />
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

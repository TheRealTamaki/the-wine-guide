---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import CategoryBadge from '../components/ui/CategoryBadge.astro';
import TableOfContents from '../components/ui/TableOfContents.astro';
import RelatedArticles from '../components/ui/RelatedArticles.astro';
import AffiliateDisclosure from '../components/ui/AffiliateDisclosure.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'articles'>;
  headings?: { depth: number; slug: string; text: string }[];
}

const { article, headings = [] } = Astro.props;
const { title, description, category, publishDate, modifiedDate, ogImage, affiliateDisclosure, relatedArticles } = article.data;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()), href: `/${category}/` },
  { label: title },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  dateModified: (modifiedDate ?? publishDate).toISOString(),
  author: { '@type': 'Organization', name: 'The Wine Guide' },
  publisher: { '@type': 'Organization', name: 'The Wine Guide', url: 'https://thewine.guide' },
};

const readingTime = Math.ceil((article.body?.length ?? 0) / 1400);
---

<BaseLayout
  {title}
  {description}
  {ogImage}
  publishDate={publishDate}
  modifiedDate={modifiedDate}
  type="article"
  {schema}
>
  <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbs} />

    <div class="mt-6 lg:grid lg:grid-cols-[1fr_16rem] lg:gap-12">
      <!-- Main content -->
      <article>
        <header class="mb-8">
          <CategoryBadge {category} />
          <h1 class="mt-3 text-[2rem] font-heading font-bold text-primary leading-tight">
            {title}
          </h1>
          <div class="mt-4 flex items-center gap-4 text-sm text-text-muted">
            <time datetime={publishDate.toISOString()}>
              {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {readingTime > 0 && (
              <span>{readingTime} min read</span>
            )}
          </div>
        </header>

        {affiliateDisclosure && <AffiliateDisclosure class="mb-6" />}

        <div class="prose">
          <slot />
        </div>

        {relatedArticles.length > 0 && (
          <div class="mt-12 pt-8 border-t border-border">
            <h2 class="text-xl font-heading font-semibold text-primary mb-6">Keep Reading</h2>
            <RelatedArticles slugs={relatedArticles} />
          </div>
        )}
      </article>

      <!-- TOC sidebar -->
      {headings.length > 2 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <TableOfContents {headings} />
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

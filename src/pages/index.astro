---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', (a) => !a.data.draft);
const latestThree = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const editorialFallbackImages = [
  { src: '/images/wine-barolo-bottle-glass.webp', alt: 'Barolo wine bottle and glass on a wooden table' },
  { src: '/images/wine-tasting-white-sommelier.webp', alt: 'Sommelier tasting white wine' },
  { src: '/images/wine-harvest-grapes-crate.webp', alt: 'Harvested wine grapes in a crate with vineyard behind' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'The Wine Guide',
  url: 'https://wineguide.co',
  description: 'Pick better bottles, pair them with confidence, and actually know what you\'re drinking.',
};
---

<BaseLayout
  title="The Wine Guide · Wine Education Without the Waffle"
  description="Pick better bottles, pair them with confidence, and actually know what you're drinking. Useful wine knowledge that respects your time."
  {schema}
>

<!-- ============ HERO: INDEX ============ -->
<section class="hp-hero-index">
  <div class="hp-hero-top">
    <div class="hp-hero-left">
      <h1>Easy To Understand<br />Wine Guides<br />For <em>Beginners</em></h1>
      <p class="hp-lede">For people who are new to wine and want down-to-earth advice and knowledge.</p>
    </div>
    <div class="hp-hero-right">
      <img src="/images/home-hero-selected-wine-night.webp" alt="Two friends sharing red wine on a sofa at night" class="hp-hero-right-bg" loading="eager" />
    </div>
  </div>

  <div class="hp-index-rows">
    <a href="/wine-basics/" class="hp-row">
      <div class="hp-row-n">&sect; 01</div>
      <h4>The <em>basics</em></h4>
      <div class="hp-row-desc">Start here. What wine is, how it's made, and the six grapes worth knowing first.</div>
    </a>
    <a href="/grapes/" class="hp-row">
      <div class="hp-row-n">&sect; 02</div>
      <h4>Grape <em>varietals</em></h4>
      <div class="hp-row-desc">The noble grapes, the forgotten ones, and the ones worth finding.</div>
    </a>
    <a href="/regions/" class="hp-row">
      <div class="hp-row-n">&sect; 03</div>
      <h4>Regions &amp; <em>maps</em></h4>
      <div class="hp-row-desc">Annotated maps of twelve wine-making regions. Pronunciations included.</div>
    </a>
    <a href="/food-wine-pairing/" class="hp-row">
      <div class="hp-row-n">&sect; 04</div>
      <h4>How to <em>taste</em></h4>
      <div class="hp-row-desc">The vocabulary of flavour, built slowly. Free worksheets at the end of each lesson.</div>
    </a>
  </div>
</section>

<!-- ============ GRAPE GRID ============ -->
<section class="hp-section">
  <div class="hp-wrap">
    <div class="hp-section-head">
      <div class="hp-section-title">
        <div class="hp-meta">&sect; 02 &middot; Begin with the six noble grapes</div>
        <h2>Learn the<br />grapes <em>first.</em></h2>
      </div>
      <div class="hp-nav-arrows">
        <button class="hp-arrow-btn" aria-label="Previous">&#8592;</button>
        <button class="hp-arrow-btn" aria-label="Next">&#8594;</button>
      </div>
    </div>
  </div>
  <div class="hp-grape-grid">
    <!-- 01 Cabernet Sauvignon -->
    <a href="/grapes/cabernet-sauvignon/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#5a1a2b; color:#f4efe6;">
        <img src="/images/grape-cabernet-sauvignon-cluster.webp" alt="Cabernet Sauvignon grapes on the vine" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">Red &middot; Bold</div>
        <div class="hp-swatch-num">01</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /kab-er-nay/</span></div>
      <h4>Cabernet<br />Sauvignon</h4>
      <p>Dense, dark, reliably structured. The grape most likely to still be drinking well at twenty.</p>
    </a>

    <!-- 02 Merlot -->
    <a href="/grapes/merlot/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#7a2738; color:#f4efe6;">
        <img src="/images/grape-merlot-red-vine-napa.webp" alt="Merlot red grapes on a vine in Napa" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">Red &middot; Plush</div>
        <div class="hp-swatch-num">02</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /mer-loh/</span></div>
      <h4>Merlot</h4>
      <p>Softer, rounder, more forgiving. The grape that taught a generation it was allowed to enjoy wine young.</p>
    </a>

    <!-- 03 Pinot Noir -->
    <a href="/grapes/pinot-noir/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#a63a52; color:#f4efe6;">
        <img src="/images/grape-pinot-noir-dark-vine.webp" alt="Pinot Noir dark grapes on a vineyard vine" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">Red &middot; Light</div>
        <div class="hp-swatch-num">03</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /pee-no-nwar/</span></div>
      <h4>Pinot<br />Noir</h4>
      <p>Quiet, translucent, endlessly opinionated about where it's grown. The grape of geography.</p>
    </a>

    <!-- 04 Chardonnay -->
    <a href="/grapes/chardonnay/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#d9b24a; color:#1f1f1f;">
        <img src="/images/grape-chardonnay-green-cluster.webp" alt="Chardonnay green grapes cluster on the vine" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">White &middot; Rich</div>
        <div class="hp-swatch-num">04</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /shar-doh-nay/</span></div>
      <h4>Chardonnay</h4>
      <p>A chameleon. Buttery and toasted in one hemisphere; lean and flinty in another. Learn the difference.</p>
    </a>

    <!-- 05 Sauvignon Blanc -->
    <a href="/grapes/sauvignon-blanc/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#8fa847; color:#f4efe6;">
        <img src="/images/grape-sauvignon-blanc-sunlit.webp" alt="Sauvignon Blanc sunlit green grapes on a Croatian vine" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">White &middot; Crisp</div>
        <div class="hp-swatch-num">05</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /soh-vin-yawn-blahnk/</span></div>
      <h4>Sauvignon<br />Blanc</h4>
      <p>High-toned and herbaceous. If Chardonnay is a wool jumper, this is a linen shirt: sharp, green, wide awake.</p>
    </a>

    <!-- 06 Riesling -->
    <a href="/grapes/riesling/" class="hp-grape-card">
      <div class="hp-swatch" style="background:#cfc06b; color:#1f1f1f;">
        <img src="/images/grape-riesling-tokaj-hungary.jpg" alt="Riesling grapes on a vine in Tokaj, Hungary" class="hp-grape-img" loading="lazy" />
        <div class="hp-swatch-label">White &middot; Aromatic</div>
        <div class="hp-swatch-num">06</div>
      </div>
      <div class="hp-meta-line"><span>Pronounced &middot; /reece-ling/</span></div>
      <h4>Riesling</h4>
      <p>The most misread grape in the world. Dry more often than sweet, and the last one left standing at dinner.</p>
    </a>
  </div>
</section>

<!-- ============ COURSE CTA ============ -->
<section class="hp-course">
  <div class="hp-course-left">
    <div>
      <div class="hp-course-kicker">A Free Eight-Part Reading Guide</div>
      <h2>The <strong>Fundamentals</strong></h2>
    </div>
    <div class="hp-lessons">
      <div class="hp-li"><span class="hp-li-n">01</span><span class="hp-li-t">Reading a label</span></div>
      <div class="hp-li"><span class="hp-li-n">02</span><span class="hp-li-t">The six grapes to know first</span></div>
      <div class="hp-li"><span class="hp-li-n">03</span><span class="hp-li-t">Acid, tannin, body: the three axes</span></div>
      <div class="hp-li"><span class="hp-li-n">04</span><span class="hp-li-t">Why old-world and new-world still matter</span></div>
      <div class="hp-li"><span class="hp-li-n">05</span><span class="hp-li-t">Building a tasting vocabulary</span></div>
      <div class="hp-li"><span class="hp-li-n">06</span><span class="hp-li-t">Food and wine, without the rules</span></div>
    </div>
    <div>
      <a href="/wine-basics/fundamentals-1-reading-a-label/" class="hp-btn hp-btn-inverse">Learn More</a>
    </div>
  </div>
  <div class="hp-course-right">
    <img
      src="/images/fundamentals-wine-still-life.webp"
      alt="Wine bottles, glasses, corkscrew, and a red wine spill on marble"
      class="hp-course-photo"
      loading="lazy"
    />
  </div>
</section>

<!-- ============ EDITORIAL FEED ============ -->
<section class="hp-editorial-section">
  <div class="hp-wrap">
    <div class="hp-section-head">
      <div class="hp-section-title">
        <div class="hp-meta">&sect; 07 &middot; The Journal &middot; Written this week</div>
        <h2>From the <em>journal.</em></h2>
      </div>
      <div class="hp-nav-arrows">
        <a href="/journal/" class="hp-all-link">All articles &rarr;</a>
      </div>
    </div>
  </div>
  <div class="hp-editorial">
    {latestThree.length > 0 ? (
      latestThree.map((article, i) => {
        const [category, ...rest] = article.id.split('/');
        const slug = rest.join('/').replace(/\.mdx?$/, '');
        const href = `/${category}/${slug}/`;
        const isLead = i === 0;
        return (
          <article class={isLead ? 'hp-ed-article hp-ed-lead' : 'hp-ed-article hp-ed-small'}>
            <a href={href} class="hp-ed-photo-link">
              <div class={`hp-ed-photo${i === 2 ? ' hp-ed-photo-alt' : ''}`}>
                {(() => {
                  const fb = editorialFallbackImages[i];
                  const imgSrc = (article.data as any).ogImage || fb.src;
                  const imgAlt = article.data.title || fb.alt;
                  return <img src={imgSrc} alt={imgAlt} class="hp-ed-img" loading="lazy" />;
                })()}
                <div class="hp-ed-caption">
                  {article.data.category?.replace(/-/g, ' ').toUpperCase() ?? 'JOURNAL'}
                </div>
              </div>
            </a>
            <div class="hp-article-kicker">
              <span>{isLead ? 'Long read' : 'Primer'}</span>
              <span>&sect; {article.data.category?.replace(/-/g, ' ') ?? 'Journal'}</span>
            </div>
            <h3><a href={href}>{article.data.title}</a></h3>
            <p>{article.data.description}</p>
          </article>
        );
      })
    ) : (
      <>
        <article class="hp-ed-article hp-ed-lead">
          <div class="hp-ed-photo">
            <img src="/images/wine-barolo-bottle-glass.webp" alt="Barolo wine bottle and glass on a wooden table" class="hp-ed-img" loading="lazy" />
            <div class="hp-ed-caption">REGIONS &middot; ITALY</div>
          </div>
          <div class="hp-article-kicker"><span>Long read &middot; 22 min</span><span>&sect; Regions</span></div>
          <h3>Barolo, in <em>five small</em> sips and one long walk.</h3>
          <p>The hill is the lesson. We walked the ridge from La Morra to Serralunga and came back with a map a beginner could use.</p>
          <div class="hp-byline">By the editors &middot; 14 April 2026</div>
        </article>
        <article class="hp-ed-article hp-ed-small">
          <div class="hp-ed-photo">
            <img src="/images/wine-tasting-white-sommelier.webp" alt="Sommelier tasting white wine" class="hp-ed-img" loading="lazy" />
            <div class="hp-ed-caption">TASTING</div>
          </div>
          <div class="hp-article-kicker"><span>Primer &middot; 9 min</span><span>&sect; Tasting</span></div>
          <h3>Acidity, quietly <em>explained.</em></h3>
          <p>Why the best wine writers keep returning to the word "zing," and what they actually mean when they do.</p>
          <div class="hp-byline">By the editors &middot; 11 April 2026</div>
        </article>
        <article class="hp-ed-article hp-ed-small">
          <div class="hp-ed-photo hp-ed-photo-alt">
            <img src="/images/wine-harvest-grapes-crate.webp" alt="Harvested wine grapes in a crate with vineyard behind" class="hp-ed-img" loading="lazy" />
            <div class="hp-ed-caption">VARIETALS</div>
          </div>
          <div class="hp-article-kicker"><span>Field notes &middot; 14 min</span><span>&sect; Varietals</span></div>
          <h3>In defence of the under-<em>ripe</em> grape.</h3>
          <p>A quiet argument for greener, lower-alcohol reds: and the Australian winemakers making them on purpose.</p>
          <div class="hp-byline">By the editors &middot; 7 April 2026</div>
        </article>
      </>
    )}
  </div>
</section>

<!-- ============ REGION MAP ============ -->
<section class="hp-region">
  <div class="hp-region-left">
    <div>
      <div class="hp-meta" style="color:#8a8177;">&sect; 03 &middot; Annotated Regions</div>
      <h2 style="margin-top:14px;">The top <em>seven</em><br />wine-producing<br />countries.</h2>
      <p style="max-width:40ch; margin-top:20px; color:#3a3530; font-size:15px; line-height:1.6;">Each country annotated: hero wines, key regions, pronunciations, and one bottle to start with.</p>
    </div>
    <div class="hp-region-list">
      <a href="/regions/france-wine-guide/" class="hp-region-row"><span class="hp-region-n">01</span><span class="hp-region-name">France</span></a>
      <a href="/regions/italy-wine-guide/" class="hp-region-row"><span class="hp-region-n">02</span><span class="hp-region-name">Italy</span></a>
      <a href="/regions/spain-wine-guide/" class="hp-region-row"><span class="hp-region-n">03</span><span class="hp-region-name">Spain</span></a>
      <a href="/regions/us-wine-guide/" class="hp-region-row"><span class="hp-region-n">04</span><span class="hp-region-name">United States</span></a>
      <a href="/regions/australia-wine-guide/" class="hp-region-row"><span class="hp-region-n">05</span><span class="hp-region-name">Australia</span></a>
      <a href="/regions/argentina-wine-guide/" class="hp-region-row"><span class="hp-region-n">06</span><span class="hp-region-name">Argentina</span></a>
      <a href="/regions/chile-wine-guide/" class="hp-region-row"><span class="hp-region-n">07</span><span class="hp-region-name">Chile</span></a>
    </div>
    <a href="/regions/" class="hp-btn" style="align-self:flex-start;">Learn More &rarr;</a>
  </div>
  <div class="hp-region-right">
    <div class="hp-map-placeholder" role="img" aria-label="World map: top seven wine-producing countries">
      <div class="hp-map-placeholder-inner">
        <div class="hp-map-kicker">PLATE III</div>
        <div class="hp-map-title">Top seven wine-producing countries</div>
        <div class="hp-map-sub">France &middot; Italy &middot; Spain &middot; United States &middot; Australia &middot; Argentina &middot; Chile</div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ============ HOMEPAGE DESIGN TOKENS ============ */
:root {
  --bg: #f4efe6;
  --bg-2: #ebe3d3;
  --ink: #1f1f1f;
  --ink-soft: #3a3530;
  --muted: #8a8177;
  --line: #1f1f1f;
  --burgundy: #5a1a2b;
  --terracotta: #8a4a2f;
  --accent: var(--burgundy);
  --paper: #ffffff;
  --serif: 'Playfair Display', Georgia, serif;
  --sans: 'Inter', system-ui, sans-serif;
  --mono: 'JetBrains Mono', ui-monospace, monospace;
  --pad: 28px;
  --gap: 24px;
  --rule: 1.5px;
  --max: 1440px;
}

/* ============ SHARED UTILITIES ============ */
.hp-wrap {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad);
}

.hp-meta {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--muted);
}

.hp-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 22px;
  background: var(--ink);
  color: var(--bg);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border: var(--rule) solid var(--ink);
  cursor: pointer;
  text-decoration: none;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}

.hp-btn:hover {
  transform: translate(-2px, -2px);
  box-shadow: 4px 4px 0 var(--ink);
  text-decoration: none;
  color: var(--bg);
}

.hp-btn-ghost {
  background: transparent;
  color: var(--ink);
}

.hp-btn-ghost:hover {
  color: var(--ink);
  box-shadow: 4px 4px 0 var(--ink);
}

.hp-btn-inverse {
  background: var(--bg);
  color: var(--ink);
  border-color: var(--bg);
}

.hp-btn-inverse:hover {
  color: var(--ink);
  box-shadow: 4px 4px 0 var(--bg);
}

/* ============ HERO: INDEX ============ */
.hp-hero-index {
  background: var(--bg);
  border-bottom: var(--rule) solid var(--line);
}

.hp-hero-top {
  display: grid;
  grid-template-columns: 2fr 1fr;
  border-bottom: var(--rule) solid var(--line);
}

.hp-hero-left {
  padding: 18px var(--pad);
  border-right: var(--rule) solid var(--line);
}

.hp-hero-right {
  padding: 18px var(--pad);
  background: var(--bg);
  color: var(--bg);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 24px;
  position: relative;
  overflow: hidden;
}

.hp-hero-right-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 1;
  z-index: 0;
}

.hp-hero-right > *:not(.hp-hero-right-bg) {
  position: relative;
  z-index: 1;
}

.hp-hero-index h1 {
  font-family: var(--serif);
  font-size: clamp(60px, 8vw, 128px);
  font-weight: 500;
  line-height: 0.95;
  letter-spacing: -0.03em;
  max-width: 14ch;
  color: var(--ink);
  margin: 0;
}

.hp-hero-index h1 em {
  font-style: italic;
  color: var(--burgundy);
}

.hp-lede {
  margin-top: 24px;
  max-width: 56ch;
  font-size: 16px;
  color: var(--ink-soft);
  line-height: 1.6;
}

.hp-cta-row {
  margin-top: 32px;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.hp-hero-right-mini {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  opacity: 0.8;
}

.hp-hero-right h3 {
  font-family: var(--serif);
  font-size: 32px;
  font-weight: 500;
  line-height: 1.05;
  color: var(--bg);
  margin: 0;
}

.hp-hero-right p {
  margin-top: 12px;
  font-size: 14px;
  line-height: 1.5;
  opacity: 0.9;
  max-width: 32ch;
}

/* Index rows */
.hp-index-rows {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.hp-row {
  padding: 28px 22px;
  border-right: var(--rule) solid var(--line);
  min-height: 220px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 14px;
  transition: background 0.2s ease;
  cursor: pointer;
  text-decoration: none;
  color: var(--ink);
}

.hp-row:last-child {
  border-right: 0;
}

.hp-row:hover {
  background: var(--bg-2);
  text-decoration: none;
  color: var(--ink);
}

.hp-row-n {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--muted);
}

.hp-row h4 {
  font-family: var(--serif);
  font-size: 30px;
  font-weight: 500;
  line-height: 1;
  letter-spacing: -0.015em;
  color: var(--ink);
  margin: 0;
}

.hp-row h4 em {
  font-style: italic;
  color: var(--accent);
}

.hp-row-desc {
  font-size: 12.5px;
  color: var(--ink-soft);
  line-height: 1.5;
}

.hp-row-count {
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
}



/* ============ SECTION SHARED ============ */
.hp-section {
  border-bottom: var(--rule) solid var(--line);
}

.hp-section-head {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: end;
  padding: 36px 0 24px;
  gap: 24px;
}

.hp-section-title {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.hp-section-head h2 {
  font-family: var(--serif);
  font-size: clamp(36px, 4.5vw, 64px);
  font-weight: 500;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0;
  line-height: 1.05;
}

.hp-section-head h2 em {
  font-style: italic;
  color: var(--accent);
}

.hp-nav-arrows {
  display: flex;
  gap: 8px;
  align-items: center;
}

.hp-arrow-btn {
  width: 44px;
  height: 44px;
  border: var(--rule) solid var(--line);
  background: transparent;
  cursor: pointer;
  display: grid;
  place-items: center;
  font-family: var(--serif);
  font-size: 20px;
  color: var(--ink);
  transition: all 0.15s ease;
}

.hp-arrow-btn:hover {
  background: var(--ink);
  color: var(--bg);
}

.hp-all-link {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 1.5px solid var(--line);
  padding-bottom: 4px;
}


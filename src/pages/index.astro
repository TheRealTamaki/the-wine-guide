---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ui/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { navGroups } from '../data/navigation';

const allArticles = await getCollection('articles', (a) => !a.data.draft);

const featured = allArticles
  .filter((a) => a.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const latest = allArticles
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 6);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'The Wine Guide',
  url: 'https://thewine.guide',
  description: 'Honest recommendations and real knowledge for everyday wine drinkers.',
};
---

<BaseLayout
  title="The Wine Guide"
  description="Honest recommendations and real knowledge for everyday wine drinkers. Wine pairings, buying guides, grape varieties, and more."
  {schema}
>
  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-2xl">
        <h1 class="font-heading text-[2.5rem] md:text-5xl font-bold leading-tight text-white">
          Real wine knowledge.<br />No nonsense.
        </h1>
        <p class="mt-5 text-lg text-white/80 leading-relaxed">
          Straightforward recommendations and honest advice for everyday wine drinkers.
          We skip the jargon and tell you exactly what to buy, what to pair, and why it matters.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/wine-basics/"
            class="inline-flex items-center gap-2 bg-cta hover:bg-cta-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200 cursor-pointer"
          >
            Start Here
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a
            href="/best-wines/"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-lg transition-colors duration-200 cursor-pointer border border-white/20"
          >
            Best Wines
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured articles -->
  {featured.length > 0 && (
    <section class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <h2 class="font-heading text-2xl font-semibold text-primary mb-6">Editor's Picks</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((article) => {
          const [category, ...rest] = article.id.split('/');
          const slug = rest.join('/').replace(/\.mdx?$/, '');
          return (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/${category}/${slug}/`}
              category={article.data.category}
              date={article.data.publishDate}
              ogImage={article.data.ogImage}
              featured
            />
          );
        })}
      </div>
    </section>
  )}

  <!-- Category navigation -->
  <section class="bg-bg-alt border-y border-border">
    <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <h2 class="font-heading text-2xl font-semibold text-primary mb-8">Explore by Topic</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {navGroups.map((group) => (
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-accent mb-4">{group.label}</h3>
            <ul class="space-y-3">
              {group.items.map((item) => (
                <li>
                  <a href={item.href} class="flex items-start gap-2 group cursor-pointer">
                    <svg class="w-4 h-4 mt-0.5 text-border-dark group-hover:text-accent transition-colors duration-200 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                    <span>
                      <span class="text-sm font-medium text-primary group-hover:text-accent transition-colors duration-200 block">{item.label}</span>
                      {item.description && (
                        <span class="text-xs text-text-muted mt-0.5 block">{item.description}</span>
                      )}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  {latest.length > 0 && (
    <section class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-14">
      <h2 class="font-heading text-2xl font-semibold text-primary mb-6">Latest Guides</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {latest.map((article) => {
          const [category, ...rest] = article.id.split('/');
          const slug = rest.join('/').replace(/\.mdx?$/, '');
          return (
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              href={`/${category}/${slug}/`}
              category={article.data.category}
              date={article.data.publishDate}
              ogImage={article.data.ogImage}
            />
          );
        })}
      </div>
    </section>
  )}

  <!-- About strip -->
  <section class="bg-accent-light border-t border-accent/20">
    <div class="max-w-[72rem] mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col md:flex-row items-center gap-6 justify-between">
      <div class="max-w-xl">
        <h2 class="font-heading text-xl font-semibold text-primary">About The Wine Guide</h2>
        <p class="mt-2 text-sm text-secondary leading-relaxed">
          We're a team of wine enthusiasts who got tired of pretentious advice. Every recommendation is tested,
          every price point is realistic, and every guide is written for real people — not sommeliers.
        </p>
      </div>
      <a
        href="/about/"
        class="flex-shrink-0 inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-semibold px-5 py-2.5 rounded-lg transition-colors duration-200 cursor-pointer text-sm"
      >
        Our Story
      </a>
    </div>
  </section>
</BaseLayout>

---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import PillarLayout from '../../layouts/PillarLayout.astro';
import ComparisonLayout from '../../layouts/ComparisonLayout.astro';

export async function getStaticPaths() {
  const CATEGORY = 'best-wines';
  const articles = await getCollection('articles', (a) =>
    a.data.category === CATEGORY && !a.data.draft
  );

  return articles.map((article) => {
    // article.id is like "best-wines/best-red-wine-under-20.mdx"
    const slug = article.id
      .replace(`${CATEGORY}/`, '')
      .replace(/\.mdx?$/, '');
    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const { templateType } = article.data;

// Top 3 picks data for listicle sidebar (images + links for click-worthy cards)
const topPicksData: Record<string, { image: string; href: string; highlight: string }[]> = {
  'best-red-wine-under-20': [
    {
      image: 'https://assets.wine.com/winecom/image/upload/e_trim/w_200,h_400,c_fit,q_auto:best,fl_progressive/bdatmb58hhuijdrgctpj.jpg',
      href: 'https://www.wine.com/product/j-lohr-estates-seven-oaks-cabernet-sauvignon-2023/4124622',
      highlight: 'Best overall value',
    },
    {
      image: 'https://assets.wine.com/winecom/image/upload/e_trim/w_200,h_400,c_fit,q_auto:best,fl_progressive/s47mm9al0f82ocv1exby.jpg',
      href: 'https://www.wine.com/product/castellani-chianti-classico-riserva-2019/2375170',
      highlight: 'Best for food pairing',
    },
    {
      image: 'https://assets.wine.com/winecom/image/upload/e_trim/w_200,h_400,c_fit,q_auto:best,fl_progressive/csragcjypok3dxolfnnf.jpg',
      href: 'https://www.wine.com/product/benmarco-malbec-2022/2669489',
      highlight: 'Best bang for your buck',
    },
  ],
};

const articleSlug = article.id.replace('best-wines/', '').replace(/\.mdx?$/, '');
const pickData = topPicksData[articleSlug] ?? [];

const topPicks = templateType === 'listicle'
  ? headings
      .filter((h) => h.depth === 2)
      .slice(0, 3)
      .map((h, i) => {
        const name = h.text.replace(/^\d+\.\s*/, '');
        return {
          rank: i + 1,
          label: name,
          slug: h.slug,
          highlight: pickData[i]?.highlight ?? '',
          image: pickData[i]?.image ?? '',
          href: pickData[i]?.href ?? '',
        };
      })
  : [];
---

{templateType === 'pillar' ? (
  <PillarLayout {article}>
    <Content />
  </PillarLayout>
) : templateType === 'comparison' ? (
  <ComparisonLayout {article} {headings}>
    <Content />
  </ComparisonLayout>
) : (
  <ArticleLayout {article} {headings} {topPicks}>
    <Content />
  </ArticleLayout>
)}
